<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Patcher.MainPage"
             BackgroundColor="{StaticResource BackgroundPrimary}"
             Title="ASLM Patcher">

    <Grid Margin="12"
          RowDefinitions="Auto,Auto,*,Auto"
          RowSpacing="8">
        <VerticalStackLayout Spacing="6">
            <Label Text="ASLM Patcher"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource LabelPrimary}" />
            <Label Text="Applying update"
                   x:Name="SubtitleLabel"
                   FontSize="13"
                   TextColor="{StaticResource LabelSecondary}" />
        </VerticalStackLayout>

        <Border Grid.Row="1"
                BackgroundColor="{StaticResource BackgroundSecondary}"
                Stroke="{StaticResource Separator}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 6"
                Padding="8">
            <Grid>
                <Label x:Name="StatusLabel"
                       Text="Starting patcher..."
                       FontSize="14"
                       TextColor="{StaticResource LabelPrimary}"
                       VerticalOptions="Center"
                       LineBreakMode="WordWrap" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                BackgroundColor="{StaticResource BackgroundSecondary}"
                Stroke="{StaticResource Separator}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 6"
                Padding="0">
            <ScrollView x:Name="LogScroll">
                <Editor x:Name="LogEditor"
                        Text=""
                        FontSize="12"
                        FontFamily="Consolas"
                        TextColor="{StaticResource LabelPrimary}"
                        BackgroundColor="Transparent"
                        IsReadOnly="True"
                        AutoSize="TextChanges"
                        Margin="0" />
            </ScrollView>
        </Border>

        <Label x:Name="FooterLabel"
               Grid.Row="3"
               Text="ASLM will start automatically when the update is finished."
               FontSize="13"
               TextColor="{StaticResource LabelSecondary}" />
    </Grid>
</ContentPage>
