<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.ModuleManagementView">

    <ContentView.GestureRecognizers>
        <TapGestureRecognizer Tapped="OnBackgroundTapped" />
    </ContentView.GestureRecognizers>

    <CollectionView x:Name="DashboardView"
                    ItemsSource="{Binding Modules}"
                    SelectionMode="None">

        <CollectionView.ItemsLayout>
            <GridItemsLayout Orientation="Vertical"
                             Span="{Binding GridSpan}"
                             VerticalItemSpacing="4"
                             HorizontalItemSpacing="4" />
        </CollectionView.ItemsLayout>

        <CollectionView.Header>
            <VerticalStackLayout Spacing="0"
                                 Margin="0,0,0,8"
                                 Padding="4">
                <Label Text="Modules"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource LabelPrimary}" />
                <Label x:Name="DashboardSubtitle"
                       Text="Manage your installed modules"
                       FontSize="14"
                       TextColor="{StaticResource LabelSecondary}"
                       Margin="0" />
            </VerticalStackLayout>
        </CollectionView.Header>

        <CollectionView.EmptyView>
            <Label Text="No modules found. Install modules via the Setup Wizard."
                   FontSize="14"
                   TextColor="{StaticResource LabelSecondary}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="0,20,0,0" />
        </CollectionView.EmptyView>

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border BackgroundColor="{StaticResource BackgroundSecondary}"
                        Stroke="{StaticResource Separator}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="0">

                    <Grid>
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0"
                                    IsVisible="{Binding HasIcon}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 4"
                                    BackgroundColor="{StaticResource BackgroundSecondary}"
                                    WidthRequest="164"
                                    HeightRequest="164"
                                    Padding="0"
                                    Margin="8,8,0,8">
                                <Image Source="{Binding IconFullPath}"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Fill" />
                            </Border>

                            <Grid Grid.Column="1"
                                  RowDefinitions="Auto,*,Auto"
                                  HeightRequest="164"
                                  Margin="8">
                                <Grid Grid.Row="0"
                                      ColumnDefinitions="*,Auto,Auto,Auto"
                                      ColumnSpacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="16"
                                           HeightRequest="24"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource LabelPrimary}"
                                           VerticalOptions="Center"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation" />

                                    <ActivityIndicator Grid.Column="1"
                                                       IsRunning="{Binding ShowHeaderBusyIndicator}"
                                                       IsVisible="{Binding ShowHeaderBusyIndicator}"
                                                       WidthRequest="24"
                                                       HeightRequest="24"
                                                       VerticalOptions="Center"
                                                       Color="{StaticResource LabelSecondary}" />

                                    <Border Grid.Column="2"
                                            IsVisible="{Binding ShowCardUpdateAction}"
                                            Background="{SolidColorBrush {StaticResource SystemGreen}}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 2"
                                            MinimumWidthRequest="50"
                                            HeightRequest="24"
                                            Padding="0"
                                            VerticalOptions="Center">
                                        <Grid ColumnDefinitions="Auto,Auto"
                                              ColumnSpacing="0"
                                              Padding="4,0">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding OpenUpdateDialogCommand}" />
                                            </Grid.GestureRecognizers>

                                            <Image Source="icon_update.png"
                                                   WidthRequest="20"
                                                   HeightRequest="20"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                            <Label Grid.Column="1"
                                                   Text="Update"
                                                   FontSize="14"
                                                   TextColor="{StaticResource LabelPrimary}"
                                                   VerticalOptions="Center"
                                                   Padding="4,0,0,0" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="3"
                                            BackgroundColor="{StaticResource BackgroundSecondary}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 4"
                                            WidthRequest="24"
                                            HeightRequest="24"
                                            Padding="0"
                                            VerticalOptions="Center">
                                        <Grid>
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding ToggleMenuCommand}" />
                                            </Grid.GestureRecognizers>

                                            <Image Source="icon_more.png"
                                                   WidthRequest="24"
                                                   HeightRequest="24"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <VerticalStackLayout Grid.Row="1"
                                                     Spacing="4"
                                                     Margin="0,4">
                                    <Label Text="{Binding VersionString}"
                                           FontSize="14"
                                           TextColor="{StaticResource LabelSecondary}" />
                                </VerticalStackLayout>

                                <Grid Grid.Row="2"
                                      ColumnDefinitions="*,*"
                                      ColumnSpacing="8"
                                      IsVisible="{Binding ShowRunningActions}">
                                    <Button Grid.Column="0"
                                            Text="Stop"
                                            ImageSource="icon_stop.png"
                                            ContentLayout="Left,4"
                                            Command="{Binding StopCommand}"
                                            BackgroundColor="{StaticResource ActionRed}"
                                            TextColor="{StaticResource LabelPrimary}"
                                            FontSize="13"
                                            HeightRequest="32"
                                            CornerRadius="4"
                                            HorizontalOptions="Fill" />
                                    <Button Grid.Column="1"
                                            Text="Restart"
                                            ImageSource="icon_restart.png"
                                            ContentLayout="Left,4"
                                            Command="{Binding RestartCommand}"
                                            BackgroundColor="{StaticResource ActionBlue}"
                                            TextColor="{StaticResource LabelPrimary}"
                                            FontSize="13"
                                            HeightRequest="32"
                                            CornerRadius="4"
                                            HorizontalOptions="Fill" />
                                </Grid>

                                <Border Grid.Row="2"
                                        BackgroundColor="{StaticResource SystemBlueOverlay}"
                                        Stroke="{StaticResource ActionBlue}"
                                        StrokeShape="RoundRectangle 4"
                                        StrokeThickness="1"
                                        StrokeDashArray="4,2"
                                        Padding="0"
                                        Margin="0"
                                        IsVisible="{Binding IsRestarting}"
                                        MinimumHeightRequest="44"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill">
                                    <HorizontalStackLayout HorizontalOptions="Center"
                                                           VerticalOptions="Center"
                                                           Spacing="8">
                                        <ActivityIndicator IsRunning="{Binding IsRestarting}"
                                                           Color="{StaticResource LabelPrimary}"
                                                           WidthRequest="16"
                                                           HeightRequest="16"
                                                           VerticalOptions="Center" />
                                        <Label Text="Restarting"
                                               TextColor="{StaticResource LabelPrimary}"
                                               FontSize="13"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>

                                <Border Grid.Row="2"
                                        BackgroundColor="{StaticResource SystemBlueOverlay}"
                                        Stroke="{StaticResource ActionBlue}"
                                        StrokeShape="RoundRectangle 4"
                                        StrokeThickness="1"
                                        StrokeDashArray="4,2"
                                        Padding="0"
                                        Margin="0"
                                        IsVisible="{Binding ShowStartingStatus}"
                                        MinimumHeightRequest="44"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill">
                                    <HorizontalStackLayout HorizontalOptions="Center"
                                                           VerticalOptions="Center"
                                                           Spacing="8">
                                        <ActivityIndicator IsRunning="{Binding ShowStartingStatus}"
                                                           Color="{StaticResource LabelPrimary}"
                                                           WidthRequest="16"
                                                           HeightRequest="16"
                                                           VerticalOptions="Center" />
                                        <Label Text="Starting"
                                               TextColor="{StaticResource LabelPrimary}"
                                               FontSize="13"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>

                                <Border Grid.Row="2"
                                        BackgroundColor="#2032D74B"
                                        Stroke="{StaticResource SystemGreen}"
                                        StrokeShape="RoundRectangle 4"
                                        StrokeThickness="1"
                                        StrokeDashArray="4,2"
                                        Padding="0"
                                        Margin="0"
                                        IsVisible="{Binding ShowUpdatingStatus}"
                                        MinimumHeightRequest="44"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill">
                                    <HorizontalStackLayout HorizontalOptions="Center"
                                                           VerticalOptions="Center"
                                                           Spacing="8">
                                        <ActivityIndicator IsRunning="{Binding ShowUpdatingStatus}"
                                                           Color="{StaticResource LabelPrimary}"
                                                           WidthRequest="16"
                                                           HeightRequest="16"
                                                           VerticalOptions="Center" />
                                        <Label Text="Updating"
                                               TextColor="{StaticResource LabelPrimary}"
                                               FontSize="13"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>

                                <Button Grid.Row="2"
                                        Text="Launch"
                                        ImageSource="icon_play.png"
                                        ContentLayout="Left,4"
                                        Command="{Binding LaunchCommand}"
                                        IsVisible="{Binding CanShowLaunchAction}"
                                        BackgroundColor="{StaticResource ActionBlue}"
                                        TextColor="{StaticResource LabelPrimary}"
                                        FontSize="13"
                                        HeightRequest="32"
                                        CornerRadius="4"
                                        HorizontalOptions="Fill"
                                        Margin="0" />
                            </Grid>
                        </Grid>

                        <Grid IsVisible="{Binding IsMenuOpen}"
                              ZIndex="10"
                              InputTransparent="False">
                            <BoxView Color="#01000000">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding CloseMenuCommand}" />
                                </BoxView.GestureRecognizers>
                            </BoxView>

                            <Border BackgroundColor="{StaticResource BackgroundTertiary}"
                                    Stroke="{StaticResource Separator}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="4"
                                    HorizontalOptions="End"
                                    VerticalOptions="Start"
                                    Margin="0,40,16,0">
                                <VerticalStackLayout Spacing="0">
                                    <Grid HeightRequest="32"
                                          Padding="4">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding CheckUpdateCommand}" />
                                        </Grid.GestureRecognizers>
                                        <Label Text="Check updates"
                                               FontSize="13"
                                               TextColor="{StaticResource LabelPrimary}"
                                               HorizontalOptions="Start"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <Grid HeightRequest="32"
                                          Padding="4">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding OpenConfigureUpdatesCommand}" />
                                        </Grid.GestureRecognizers>
                                        <Label Text="Configure updates"
                                               FontSize="13"
                                               TextColor="{StaticResource LabelPrimary}"
                                               HorizontalOptions="Start"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentView>
