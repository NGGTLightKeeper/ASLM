<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.ModuleManagementView">

    <CollectionView x:Name="DashboardView"
                    Margin="12,16"
                    ItemsSource="{Binding Modules}"
                    SelectionMode="None">

        <CollectionView.ItemsLayout>
            <GridItemsLayout Orientation="Vertical"
                             Span="{Binding GridSpan}"
                             VerticalItemSpacing="4"
                             HorizontalItemSpacing="4" />
        </CollectionView.ItemsLayout>

        <CollectionView.Header>
            <VerticalStackLayout Spacing="8" Margin="4,0,4,8">
                <Label Text="Modules"
                       FontSize="24" FontAttributes="Bold"
                       TextColor="{StaticResource LabelPrimary}" />
                <Label x:Name="DashboardSubtitle"
                       Text="Manage your installed modules"
                       FontSize="14" TextColor="{StaticResource LabelSecondary}"
                       Margin="0,0,0,8" />
            </VerticalStackLayout>
        </CollectionView.Header>

        <CollectionView.EmptyView>
            <Label Text="No modules found. Install modules via the Setup Wizard."
                   FontSize="14"
                   TextColor="{StaticResource LabelSecondary}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="0,20,0,0" />
        </CollectionView.EmptyView>

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border BackgroundColor="{StaticResource BackgroundSecondary}"
                        Stroke="{StaticResource Separator}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="0">

                    <Grid ColumnDefinitions="Auto, *">
                        <!-- Icon -->
                        <Border Grid.Column="0"
                                IsVisible="{Binding HasIcon}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 0"
                                BackgroundColor="{StaticResource BackgroundSecondary}"
                                WidthRequest="164"
                                HeightRequest="164"
                                Padding="0"
                                Margin="8,8,0,8">
                            <Image Source="{Binding IconFullPath}"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Fill" />
                        </Border>

                        <!-- Right side: Text + Buttons -->
                        <Grid Grid.Column="1"
                              RowDefinitions="*, Auto, Auto"
                              Padding="8">

                            <!-- Text area (top) -->
                            <VerticalStackLayout Grid.Row="0" Spacing="2">
                                <Label Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource LabelPrimary}" />
                                <Label Text="{Binding VersionString}"
                                       FontSize="13"
                                       TextColor="{StaticResource LabelSecondary}" />
                                <Label Text="{Binding UpdateStatus}"
                                       FontSize="12"
                                       TextColor="{StaticResource LabelSecondary}"
                                       Margin="0,4,0,0" />
                            </VerticalStackLayout>

                            <!-- Update controls -->
                            <Grid Grid.Row="1"
                                  RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="*,*,Auto,Auto"
                                  ColumnSpacing="6"
                                  RowSpacing="6"
                                  Margin="0,6,0,8">
                                <Picker Grid.Column="0"
                                        ItemsSource="{Binding SourceModeOptions}"
                                        SelectedItem="{Binding SelectedSourceMode, Mode=TwoWay}"
                                        FontSize="12"
                                        HeightRequest="32"
                                        TextColor="{StaticResource LabelPrimary}"
                                        TitleColor="{StaticResource LabelSecondary}"
                                        BackgroundColor="{StaticResource BackgroundSecondary}" />
                                <Picker Grid.Column="1"
                                        ItemsSource="{Binding ChannelOptions}"
                                        SelectedItem="{Binding SelectedChannel, Mode=TwoWay}"
                                        IsVisible="{Binding IsReleaseMode}"
                                        FontSize="12"
                                        HeightRequest="32"
                                        TextColor="{StaticResource LabelPrimary}"
                                        TitleColor="{StaticResource LabelSecondary}"
                                        BackgroundColor="{StaticResource BackgroundSecondary}" />
                                <Picker Grid.Column="1"
                                        ItemsSource="{Binding BranchOptions}"
                                        SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                                        IsVisible="{Binding IsBranchMode}"
                                        FontSize="12"
                                        HeightRequest="32"
                                        TextColor="{StaticResource LabelPrimary}"
                                        TitleColor="{StaticResource LabelSecondary}"
                                        BackgroundColor="{StaticResource BackgroundSecondary}" />
                                <Button Grid.Column="2"
                                        Text="Check"
                                        Command="{Binding CheckUpdateCommand}"
                                        FontSize="12"
                                        HeightRequest="32"
                                        CornerRadius="4"
                                        Padding="8,0"
                                        BackgroundColor="{StaticResource BackgroundSecondary}"
                                        TextColor="{StaticResource LabelSecondary}" />
                                <Button Grid.Column="3"
                                        Text="Update"
                                        Command="{Binding UpdateCommand}"
                                        IsEnabled="{Binding CanUpdate}"
                                        FontSize="12"
                                        HeightRequest="32"
                                        CornerRadius="4"
                                        Padding="8,0"
                                        BackgroundColor="{StaticResource ActionBlue}"
                                        TextColor="{StaticResource LabelPrimary}" />
                                <ActivityIndicator Grid.Row="1"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="4"
                                                   IsRunning="{Binding IsUpdating}"
                                                   IsVisible="{Binding IsUpdating}"
                                                   HeightRequest="16"
                                                   Color="{StaticResource LabelPrimary}" />
                            </Grid>

                            <!-- Action buttons (bottom) -->

                            <!-- Running: Stop + Restart -->
                            <Grid Grid.Row="2"
                                  ColumnDefinitions="*, *"
                                  ColumnSpacing="8"
                                  IsVisible="{Binding IsRunning}">
                                <Button Grid.Column="0"
                                        Text="Stop"
                                        ImageSource="icon_stop.png"
                                        ContentLayout="Left,4"
                                        Command="{Binding StopCommand}"
                                        BackgroundColor="{StaticResource ActionRed}"
                                        TextColor="{StaticResource LabelPrimary}"
                                        FontSize="13"
                                        HeightRequest="24"
                                        CornerRadius="4"
                                        IsVisible="{Binding IsNotRestarting}"
                                        HorizontalOptions="Fill" />
                                <Button Grid.Column="1"
                                        Text="Restart"
                                        ImageSource="icon_restart.png"
                                        ContentLayout="Left,4"
                                        Command="{Binding RestartCommand}"
                                        BackgroundColor="{StaticResource ActionBlue}"
                                        TextColor="{StaticResource LabelPrimary}"
                                        FontSize="13"
                                        HeightRequest="24"
                                        CornerRadius="4"
                                        IsVisible="{Binding IsNotRestarting}"
                                        HorizontalOptions="Fill" />
                                <Border Grid.Column="0" Grid.ColumnSpan="2"
                                        BackgroundColor="{StaticResource SystemBlueOverlay}"
                                        Stroke="{StaticResource ActionBlue}"
                                        StrokeShape="RoundRectangle 4"
                                        StrokeThickness="1"
                                        StrokeDashArray="4,2"
                                        Padding="0"
                                        Margin="0"
                                        IsVisible="{Binding IsRestarting}"
                                        MinimumHeightRequest="44"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill">
                                    <HorizontalStackLayout HorizontalOptions="Center"
                                                           VerticalOptions="Center"
                                                           Spacing="8">
                                        <ActivityIndicator IsRunning="{Binding IsRestarting}"
                                                           Color="{StaticResource LabelPrimary}"
                                                           WidthRequest="16"
                                                           HeightRequest="16"
                                                           VerticalOptions="Center" />
                                        <Label Text="Restarting"
                                               TextColor="{StaticResource LabelPrimary}"
                                               FontSize="13"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>

                            <!-- Stopped: Launch -->
                            <Button Grid.Row="2"
                                    Text="Launch"
                                    ImageSource="icon_play.png"
                                    ContentLayout="Left,4"
                                    Command="{Binding LaunchCommand}"
                                    IsVisible="{Binding IsStopped}"
                                    BackgroundColor="{StaticResource ActionBlue}"
                                    TextColor="{StaticResource LabelPrimary}"
                                    FontSize="13"
                                    HeightRequest="24"
                                    CornerRadius="4"
                                    HorizontalOptions="Fill"
                                    Margin="0" />
                        </Grid>
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentView>
