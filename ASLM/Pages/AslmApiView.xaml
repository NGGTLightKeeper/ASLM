<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.AslmApiView">

    <Grid RowDefinitions="Auto,Auto,*"
          RowSpacing="12"
          Padding="4">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <VerticalStackLayout Spacing="0">
                <Label Text="ASLM API"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource LabelPrimary}" />
            </VerticalStackLayout>

            <Button Grid.Column="1"
                    Text="Open"
                    HeightRequest="31"
                    MinimumHeightRequest="31"
                    CornerRadius="6"
                    Padding="12,0"
                    FontSize="13"
                    IsEnabled="{Binding CanOpenServer}"
                    BackgroundColor="{StaticResource ActionBlue}"
                    TextColor="{StaticResource LabelPrimary}"
                    VerticalOptions="Center"
                    Clicked="OnOpenServerClicked" />
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="{StaticResource BackgroundSecondary}"
                Stroke="{StaticResource Separator}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8"
                Padding="8"
                Margin="0,4,0,0">
            <Label Text="{Binding ServerUrl}"
                   FontSize="13"
                   TextColor="{StaticResource LabelPrimary}"
                   LineBreakMode="TailTruncation" />
        </Border>

        <Grid Grid.Row="2"
              RowDefinitions="Auto,*"
              RowSpacing="8"
              Margin="0">
            <Label Text="Hosts"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="{StaticResource LabelPrimary}"
                   Margin="0,4,0,0" />

            <Border Grid.Row="1"
                    BackgroundColor="{StaticResource BackgroundSecondary}"
                    Stroke="{StaticResource Separator}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="0">
                <CollectionView ItemsSource="{Binding Hosts}"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center"
                                             VerticalOptions="Center"
                                             Spacing="6"
                                             Margin="24">
                            <Label Text="No hosts"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource LabelPrimary}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  RowSpacing="4"
                                  Padding="8">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding Title}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource LabelPrimary}"
                                           LineBreakMode="TailTruncation"
                                           VerticalTextAlignment="Center" />

                                    <Border BackgroundColor="{StaticResource BackgroundTertiary}"
                                            Stroke="{StaticResource Separator}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 4"
                                            Padding="4,1"
                                            IsVisible="{Binding IsModuleDisabled}"
                                            VerticalOptions="Center">
                                        <Label Text="{Binding ModuleStatusText}"
                                               FontSize="12"
                                               TextColor="{StaticResource LabelSecondary}" />
                                    </Border>
                                </HorizontalStackLayout>

                                <Grid Grid.Row="1"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8">
                                    <ImageButton Source="icon_copy.png"
                                                 WidthRequest="24"
                                                 HeightRequest="24"
                                                 MinimumWidthRequest="24"
                                                 MinimumHeightRequest="24"
                                                 Padding="4"
                                                 CornerRadius="4"
                                                 Command="{Binding CopyCommand}"
                                                 ToolTipProperties.Text="Copy address"
                                                 BackgroundColor="{StaticResource BackgroundTertiary}"
                                                 VerticalOptions="Center" />

                                    <Label Grid.Column="1"
                                           Text="{Binding MirrorUrl}"
                                           FontSize="12"
                                           TextColor="{StaticResource LabelSecondary}"
                                           VerticalTextAlignment="Center"
                                           LineBreakMode="TailTruncation" />
                                </Grid>

                                <BoxView Grid.Row="2"
                                         HeightRequest="1"
                                         Color="{StaticResource Separator}"
                                         Opacity="0.5"
                                         Margin="0,2,0,-8" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
        </Grid>
    </Grid>
</ContentView>
