<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.DownloadModulesView">
    <Grid>
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
            <Image Source="{StaticResource IconRibbon}"
                   WidthRequest="48"
                   HeightRequest="48"
                   HorizontalOptions="Center" />
            <Label Text="Download Modules"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource LabelPrimary}"
                   HorizontalOptions="Center" />
            <Label Text="Module store will be connected to API"
                   FontSize="14"
                   TextColor="{StaticResource LabelSecondary}"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>
    </Grid>
</ContentView>
