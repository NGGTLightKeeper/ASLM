<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:ASLM.Services"
             x:Class="ASLM.Pages.ConsolesView">

    <Grid RowDefinitions="Auto,*"
          RowSpacing="12"
          Padding="4">

        <Grid Grid.Row="0">
            <VerticalStackLayout>
                <Label Text="Consoles"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource LabelPrimary}" />
                <Label Text="{Binding Subtitle}"
                       FontSize="14"
                       TextColor="{StaticResource LabelSecondary}" />
            </VerticalStackLayout>
        </Grid>

        <Grid x:Name="WorkspaceLayout"
              Grid.Row="1"
              ColumnDefinitions="260,260,*"
              ColumnSpacing="8"
              RowSpacing="12"
              Margin="0,4,0,0">

            <Border x:Name="ModulesPanel"
                    Grid.Column="0"
                    BackgroundColor="{StaticResource BackgroundSecondary}"
                    Stroke="{StaticResource Separator}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="8">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="4">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Modules"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource LabelPrimary}" />
                    </VerticalStackLayout>

                    <CollectionView x:Name="ModulesCollection"
                                    Grid.Row="1"
                                    ItemsSource="{Binding Modules}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnModuleSelectionChanged"
                                    Margin="0">
                        <CollectionView.EmptyView>
                            <Label Text="No active modules"
                                   FontSize="13"
                                   TextColor="{StaticResource LabelSecondary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12"
                                        Margin="0,0,0,4">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource LabelPrimary}" />
                                        <Label Text="{Binding StatusText}"
                                               FontSize="12"
                                               TextColor="{StaticResource LabelSecondary}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <Border x:Name="SessionsPanel"
                    Grid.Column="1"
                    BackgroundColor="{StaticResource BackgroundSecondary}"
                    Stroke="{StaticResource Separator}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="8">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="4">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Consoles"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource LabelPrimary}" />
                    </VerticalStackLayout>

                    <CollectionView x:Name="SessionsCollection"
                                    Grid.Row="1"
                                    ItemsSource="{Binding Sessions}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnSessionSelectionChanged"
                                    Margin="0">
                        <CollectionView.EmptyView>
                            <Label Text="No consoles"
                                   FontSize="13"
                                   TextColor="{StaticResource LabelSecondary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12"
                                        Margin="0,0,0,4">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Title}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource LabelPrimary}" />
                                        <Label Text="{Binding StatusText}"
                                               FontSize="12"
                                               TextColor="{StaticResource LabelSecondary}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <Border x:Name="OutputPanel"
                    Grid.Column="2"
                    BackgroundColor="{StaticResource BackgroundSecondary}"
                    Stroke="{StaticResource Separator}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="8">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="8">
                    <VerticalStackLayout x:Name="OutputHeaderPanel"
                                         Spacing="0">
                        <Label Text="{Binding SelectedSessionTitle}"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource LabelPrimary}" />
                    </VerticalStackLayout>

                    <services:ConsoleOutputView x:Name="ConsoleOutputHost"
                                                Grid.Row="1"
                                                Text="{Binding SelectedSessionText}"
                                                SessionKey="{Binding SelectedSessionKey}"
                                                HorizontalOptions="Fill"
                                                VerticalOptions="Fill" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentView>
