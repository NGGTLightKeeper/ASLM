<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.ConsolesView">

    <Grid RowDefinitions="Auto,*"
          RowSpacing="12"
          Margin="12,16">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <VerticalStackLayout Spacing="4">
                <Label Text="Consoles"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource LabelPrimary}" />
                <Label Text="{Binding Subtitle}"
                       FontSize="14"
                       TextColor="{StaticResource LabelSecondary}" />
            </VerticalStackLayout>

            <HorizontalStackLayout Grid.Column="1"
                                   Spacing="10"
                                   VerticalOptions="Center">
                <Label Text="Follow output"
                       FontSize="13"
                       VerticalOptions="Center"
                       TextColor="{StaticResource LabelSecondary}" />
                <Switch IsToggled="{Binding FollowOutput}"
                        VerticalOptions="Center" />
                <HorizontalStackLayout Spacing="6"
                                       VerticalOptions="Center">
                    <CheckBox IsChecked="{Binding ShowCompletedProcesses}"
                              CheckedChanged="OnShowCompletedProcessesChanged"
                              VerticalOptions="Center" />
                    <Label Text="Show completed processes"
                           FontSize="13"
                           VerticalOptions="Center"
                           TextColor="{StaticResource LabelSecondary}" />
                </HorizontalStackLayout>
                <Button Text="Refresh"
                        Clicked="OnRefreshClicked"
                        BackgroundColor="{StaticResource BackgroundSecondary}"
                        TextColor="{StaticResource LabelPrimary}"
                        FontSize="13"
                        HeightRequest="32"
                        CornerRadius="6" />
            </HorizontalStackLayout>
        </Grid>

        <Grid x:Name="WorkspaceLayout"
              Grid.Row="1"
              ColumnDefinitions="280,320,*"
              ColumnSpacing="12"
              RowSpacing="12">

            <Border x:Name="ModulesPanel"
                    Grid.Column="0"
                    BackgroundColor="{StaticResource BackgroundSecondary}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12"
                    Padding="12">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="10">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Modules"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource LabelPrimary}" />
                        <Label Text="{Binding ModuleListCaption}"
                               FontSize="12"
                               TextColor="{StaticResource LabelSecondary}" />
                    </VerticalStackLayout>

                    <CollectionView x:Name="ModulesCollection"
                                    Grid.Row="1"
                                    ItemsSource="{Binding Modules}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnModuleSelectionChanged">
                        <CollectionView.EmptyView>
                            <Label Text="Active modules will appear here."
                                   FontSize="13"
                                   TextColor="{StaticResource LabelSecondary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="{StaticResource BackgroundPrimary}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 10"
                                        Padding="10"
                                        Margin="0,0,0,6">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource LabelPrimary}" />
                                        <Label Text="{Binding StatusText}"
                                               FontSize="12"
                                               TextColor="{StaticResource LabelSecondary}" />
                                        <Label Text="{Binding ActivityText}"
                                               FontSize="12"
                                               TextColor="{StaticResource LabelSecondary}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <Border x:Name="SessionsPanel"
                    Grid.Column="1"
                    BackgroundColor="{StaticResource BackgroundSecondary}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12"
                    Padding="12">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="10">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Consoles"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource LabelPrimary}" />
                        <Label Text="{Binding SessionListCaption}"
                               FontSize="12"
                               TextColor="{StaticResource LabelSecondary}" />
                    </VerticalStackLayout>

                    <CollectionView x:Name="SessionsCollection"
                                    Grid.Row="1"
                                    ItemsSource="{Binding Sessions}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnSessionSelectionChanged">
                        <CollectionView.EmptyView>
                            <Label Text="This module has no console sessions yet."
                                   FontSize="13"
                                   TextColor="{StaticResource LabelSecondary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="{StaticResource BackgroundPrimary}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 10"
                                        Padding="10"
                                        Margin="0,0,0,6">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Title}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource LabelPrimary}" />
                                        <Label Text="{Binding StatusText}"
                                               FontSize="12"
                                               TextColor="{StaticResource LabelSecondary}" />
                                        <Label Text="{Binding Preview}"
                                               FontSize="12"
                                               TextColor="{StaticResource LabelSecondary}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <Border x:Name="OutputPanel"
                    Grid.Column="2"
                    BackgroundColor="{StaticResource BackgroundSecondary}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12"
                    Padding="12">
                <Grid RowDefinitions="Auto,Auto,*,Auto"
                      RowSpacing="10">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding SelectedSessionTitle}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource LabelPrimary}" />
                        <Label Text="{Binding SelectedSessionStatus}"
                               FontSize="12"
                               TextColor="{StaticResource LabelSecondary}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="1"
                                         Spacing="2">
                        <Label Text="{Binding SelectedSessionDescription}"
                               FontSize="12"
                               TextColor="{StaticResource LabelSecondary}"
                               LineBreakMode="TailTruncation"
                               MaxLines="2" />
                        <Label Text="{Binding SelectedSessionCommandLine}"
                               FontSize="12"
                               TextColor="{StaticResource LabelSecondary}"
                               LineBreakMode="MiddleTruncation"
                               MaxLines="2" />
                    </VerticalStackLayout>

                    <Editor x:Name="OutputEditor"
                            Grid.Row="2"
                            Text="{Binding SelectedSessionText}"
                            IsReadOnly="True"
                            AutoSize="Disabled"
                            FontFamily="Consolas"
                            FontSize="12"
                            TextColor="{StaticResource LabelPrimary}"
                            BackgroundColor="{StaticResource BackgroundPrimary}" />

                    <Label Grid.Row="3"
                           Text="{Binding SelectedSessionFooter}"
                           FontSize="12"
                           TextColor="{StaticResource LabelSecondary}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentView>
