<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.ModuleUpdateDialogView"
             x:Name="RootView"
             BackgroundColor="#40000000">

    <ContentView.GestureRecognizers>
        <TapGestureRecognizer Tapped="OnBackgroundTapped" />
    </ContentView.GestureRecognizers>

    <Border x:Name="DialogBorder"
            WidthRequest="940"
            HeightRequest="620"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            BackgroundColor="{StaticResource BackgroundSecondary}"
            Stroke="{StaticResource Separator}"
            StrokeThickness="1"
            Padding="0"
            StrokeShape="RoundRectangle 10">

        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnDialogTapped" />
        </Border.GestureRecognizers>

        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="0"
              Padding="12">

            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  Margin="0,0,0,8">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding DialogTitle, Source={x:Reference RootView}}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource LabelPrimary}" />
                    <Label Text="{Binding DialogSubtitle, Source={x:Reference RootView}}"
                           FontSize="14"
                           TextColor="{StaticResource LabelSecondary}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="&#x2715;"
                        FontSize="17"
                        WidthRequest="34"
                        HeightRequest="34"
                        Padding="0"
                        Margin="0"
                        ToolTipProperties.Text="Close module updates"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource LabelSecondary}"
                        CornerRadius="6"
                        VerticalOptions="Center"
                        Clicked="OnCloseClicked" />
            </Grid>

            <Grid Grid.Row="1"
                  RowDefinitions="Auto,Auto,*"
                  RowSpacing="8"
                  Padding="0">
                    <Border Grid.Row="0"
                            BackgroundColor="{StaticResource BackgroundTertiary}"
                            Stroke="{StaticResource Separator}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 6"
                            Padding="8">
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Current version"
                                       FontSize="13"
                                       TextColor="{StaticResource LabelSecondary}" />
                                <Label Text="{Binding CurrentVersionLabel, Source={x:Reference RootView}}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource LabelPrimary}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4">
                                <Label Text="Selected target"
                                       FontSize="13"
                                       TextColor="{StaticResource LabelSecondary}" />
                                <Label Text="{Binding TargetVersionLabel, Source={x:Reference RootView}}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource LabelPrimary}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            BackgroundColor="{StaticResource BackgroundTertiary}"
                            Stroke="{StaticResource Separator}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 0"
                            Padding="0,8,0,0">
                        <VerticalStackLayout Spacing="8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Update source"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource LabelPrimary}" />
                                <Label Text="Preferences are saved automatically."
                                       FontSize="13"
                                       TextColor="{StaticResource LabelSecondary}" />
                            </VerticalStackLayout>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Search mode"
                                           FontSize="13"
                                           TextColor="{StaticResource LabelSecondary}" />
                                    <Border BackgroundColor="#19191C"
                                            Stroke="{StaticResource Separator}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 6"
                                            Padding="8,0">
                                        <Picker x:Name="SourceModePicker"
                                                ItemsSource="{Binding SourceModeOptions, Source={x:Reference RootView}}"
                                                SelectedItem="{Binding SelectedSourceMode, Source={x:Reference RootView}, Mode=TwoWay}"
                                                SelectedIndexChanged="OnSourceModeSelectionChanged"
                                                FontSize="13"
                                                HeightRequest="44"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource LabelPrimary}"
                                                TitleColor="{StaticResource LabelSecondary}" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="6"
                                                     IsVisible="{Binding IsReleaseMode, Source={x:Reference RootView}}">
                                    <Label Text="Release version"
                                           FontSize="13"
                                           TextColor="{StaticResource LabelSecondary}" />
                                    <Border BackgroundColor="#19191C"
                                            Stroke="{StaticResource Separator}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="12,0">
                                        <Picker x:Name="ReleasePicker"
                                                ItemsSource="{Binding ReleaseOptions, Source={x:Reference RootView}}"
                                                SelectedItem="{Binding SelectedReleaseOption, Source={x:Reference RootView}, Mode=TwoWay}"
                                                SelectedIndexChanged="OnReleaseSelectionChanged"
                                                ItemDisplayBinding="{Binding DisplayName}"
                                                FontSize="13"
                                                HeightRequest="44"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource LabelPrimary}"
                                                TitleColor="{StaticResource LabelSecondary}" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="6"
                                                     IsVisible="{Binding IsBranchMode, Source={x:Reference RootView}}">
                                    <Label Text="Repository branch"
                                           FontSize="12"
                                           TextColor="{StaticResource LabelSecondary}" />
                                    <Border BackgroundColor="#19191C"
                                            Stroke="{StaticResource Separator}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 6"
                                            Padding="8,0">
                                        <Picker x:Name="BranchPicker"
                                                ItemsSource="{Binding BranchOptions, Source={x:Reference RootView}}"
                                                SelectedItem="{Binding SelectedBranch, Source={x:Reference RootView}, Mode=TwoWay}"
                                                SelectedIndexChanged="OnBranchSelectionChanged"
                                                FontSize="13"
                                                HeightRequest="44"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource LabelPrimary}"
                                                TitleColor="{StaticResource LabelSecondary}" />
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="2"
                            BackgroundColor="{StaticResource BackgroundTertiary}"
                            Stroke="{StaticResource Separator}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 0"
                            Padding="0,8,0,0"
                            VerticalOptions="Fill">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*"
                              RowSpacing="1">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding ActivityTitle, Source={x:Reference RootView}}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource LabelPrimary}" />
                                <Label Text="{Binding ActivityStatus, Source={x:Reference RootView}}"
                                       FontSize="13"
                                       TextColor="{StaticResource LabelSecondary}"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>

                            <Label Grid.Row="1"
                                   Text="Overall progress"
                                   FontSize="10"
                                   TextColor="{StaticResource LabelSecondary}"
                                   IsVisible="{Binding HasActivityProgress, Source={x:Reference RootView}}" />

                            <ProgressBar Grid.Row="2"
                                         Progress="{Binding OverallProgress, Source={x:Reference RootView}}"
                                         ProgressColor="{StaticResource ActionBlue}"
                                         HeightRequest="6"
                                         IsVisible="{Binding HasActivityProgress, Source={x:Reference RootView}}" />

                            <Label Grid.Row="3"
                                   Text="{Binding DownloadDetail, Source={x:Reference RootView}}"
                                   FontSize="10"
                                   TextColor="{StaticResource LabelSecondary}"
                                   IsVisible="{Binding HasDownloadDetail, Source={x:Reference RootView}}" />

                            <ProgressBar Grid.Row="4"
                                         Progress="{Binding FileProgress, Source={x:Reference RootView}}"
                                         ProgressColor="{StaticResource ActionGreen}"
                                         HeightRequest="4"
                                         IsVisible="{Binding HasActivityProgress, Source={x:Reference RootView}}" />

                            <ScrollView x:Name="LogScroll"
                                        Grid.Row="5"
                                        IsVisible="{Binding HasLog, Source={x:Reference RootView}}"
                                        Orientation="Vertical"
                                        VerticalScrollBarVisibility="Always"
                                        VerticalOptions="Fill"
                                        BackgroundColor="#19191C"
                                        Margin="0,4,0,0">
                                <Label x:Name="LogEditor"
                                       Text="{Binding LogText, Source={x:Reference RootView}}"
                                       FontSize="12"
                                       FontFamily="Consolas"
                                       TextColor="{StaticResource LabelPrimary}"
                                       BackgroundColor="#19191C"
                                       LineBreakMode="WordWrap"
                                       Padding="8" />
                            </ScrollView>
                        </Grid>
                    </Border>
            </Grid>

            <Grid Grid.Row="2"
                  ColumnDefinitions="*,Auto,Auto,Auto"
                  ColumnSpacing="8"
                  Margin="0,14,0,0">
                <ActivityIndicator Grid.Column="1"
                                   IsVisible="{Binding IsBusy, Source={x:Reference RootView}}"
                                   IsRunning="{Binding IsBusy, Source={x:Reference RootView}}"
                                   Color="{StaticResource LabelPrimary}"
                                   VerticalOptions="Center" />

                <Button Grid.Column="2"
                        Text="Check updates"
                        HeightRequest="36"
                        MinimumHeightRequest="36"
                        CornerRadius="6"
                        Padding="8,0"
                        BackgroundColor="{StaticResource SystemGray4}"
                        TextColor="{StaticResource LabelPrimary}"
                        IsEnabled="{Binding CanCheckUpdates, Source={x:Reference RootView}}"
                        Clicked="OnCheckUpdatesClicked" />

                <Button Grid.Column="3"
                        Text="Install update"
                        HeightRequest="36"
                        MinimumHeightRequest="36"
                        CornerRadius="6"
                        Padding="8,0"
                        BackgroundColor="{StaticResource ActionBlue}"
                        TextColor="{StaticResource LabelPrimary}"
                        IsVisible="{Binding ShowInstallAction, Source={x:Reference RootView}}"
                        IsEnabled="{Binding CanInstallUpdate, Source={x:Reference RootView}}"
                        Clicked="OnInstallUpdateClicked" />
            </Grid>
        </Grid>
    </Border>

</ContentView>
