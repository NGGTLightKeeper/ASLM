<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.NotificationsView"
             x:Name="RootView"
             BackgroundColor="Transparent">

    <Grid>
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnBackgroundTapped" />
        </Grid.GestureRecognizers>

        <Border x:Name="NotificationsPopup"
                WidthRequest="360"
                HeightRequest="480"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                BackgroundColor="{DynamicResource BackgroundTertiary}"
                Stroke="{DynamicResource Separator}"
                StrokeThickness="1"
                Padding="0"
                StrokeShape="RoundRectangle 12">

            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnDialogTapped" />
            </Border.GestureRecognizers>

            <Grid RowDefinitions="Auto,Auto,*,Auto"
                  RowSpacing="4"
                  Margin="8">

                <!-- Header: title + Clear all + close -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="4">
                    <Label x:Name="TitleLabel"
                           Grid.Column="0"
                           Text="Notifications"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource LabelPrimary}"
                           VerticalOptions="Center" />

                    <Button x:Name="ClearAllButton"
                            Grid.Column="1"
                            Text="Clear all"
                            FontSize="12"
                            HeightRequest="28"
                            MinimumHeightRequest="28"
                            Padding="8,0"
                            Margin="0"
                            BackgroundColor="{DynamicResource BackgroundTertiary}"
                            TextColor="{DynamicResource LabelSecondary}"
                            CornerRadius="6"
                            VerticalOptions="Center"
                            IsEnabled="{Binding HasAnyNotifications}"
                            Clicked="OnClearAllClicked" />

                    <Button Grid.Column="2"
                            Text="&#x2715;"
                            FontSize="17"
                            WidthRequest="32"
                            MinimumWidthRequest="32"
                            HeightRequest="32"
                            MinimumHeightRequest="32"
                            Padding="0"
                            Margin="0"
                            BackgroundColor="Transparent"
                            TextColor="{DynamicResource LabelSecondary}"
                            CornerRadius="6"
                            VerticalOptions="Center"
                            Clicked="OnCloseClicked" />
                </Grid>

                <!-- Section label -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="*">
                    <Label Text="{Binding SectionTitle}"
                           FontSize="12"
                           TextColor="{DynamicResource LabelPrimary}" />
                </Grid>

                <!-- Notification list -->
                <Grid Grid.Row="2">
                    <CollectionView ItemsSource="{Binding VisibleNotifications}"
                                    SelectionMode="None"
                                    VerticalScrollBarVisibility="Never"
                                    IsVisible="{Binding HasVisibleNotifications}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical"
                                               ItemSpacing="0" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid RowDefinitions="Auto,Auto"
                                      RowSpacing="12">
                                    <Grid ColumnDefinitions="4,*,Auto"
                                          ColumnSpacing="8">
                                        <BoxView BackgroundColor="{Binding AccentColor}"
                                                 WidthRequest="4"
                                                 HeightRequest="32"
                                                 VerticalOptions="Start"
                                                 Margin="0,4" />

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="2">
                                            <Label Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="{DynamicResource LabelPrimary}"
                                                   MaxLines="1"
                                                   LineBreakMode="TailTruncation" />

                                            <Label Text="{Binding Message}"
                                                   FontSize="12"
                                                   TextColor="{DynamicResource LabelPrimary}"
                                                   MaxLines="1"
                                                   LineBreakMode="TailTruncation" />

                                            <!-- Active transfer filename: only when it adds info beyond Message -->
                                            <Label Text="{Binding ActiveTransferLabel}"
                                                   FontSize="12"
                                                   TextColor="{DynamicResource LabelSecondary}"
                                                   MaxLines="1"
                                                   LineBreakMode="TailTruncation"
                                                   IsVisible="{Binding ShowActiveTransferInCard}" />

                                            <!-- Status message: hidden during active download, shown after completion -->
                                            <Label Text="{Binding StatusText}"
                                                   FontSize="12"
                                                   TextColor="{DynamicResource LabelSecondary}"
                                                   MaxLines="1"
                                                   LineBreakMode="TailTruncation"
                                                   IsVisible="{Binding ShowStatusInCard}" />

                                            <!-- Byte progress detail, Speed, percent — visible only during active download -->
                                            <Grid ColumnDefinitions="*,Auto,Auto"
                                                  ColumnSpacing="8"
                                                  IsVisible="{Binding ShowDownloadMetricsRow}"
                                                  HeightRequest="18">
                                                <Label Grid.Column="0"
                                                       Text="{Binding DetailText}"
                                                       FontSize="11"
                                                       TextColor="{DynamicResource LabelSecondary}"
                                                       VerticalTextAlignment="Center"
                                                       LineBreakMode="TailTruncation"
                                                       IsVisible="{Binding HasDetailText}" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding TransferSpeedDisplay}"
                                                       FontSize="11"
                                                       TextColor="{DynamicResource LabelSecondary}"
                                                       VerticalTextAlignment="Center"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Grid.Column="2"
                                                       Text="{Binding TransferPercentDisplay}"
                                                       FontSize="11"
                                                       TextColor="{DynamicResource LabelSecondary}"
                                                       VerticalTextAlignment="Center" />
                                            </Grid>

                                            <ProgressBar Progress="{Binding ProgressFraction}"
                                                         IsVisible="{Binding HasProgress}"
                                                         HeightRequest="4"
                                                         ProgressColor="{DynamicResource ActionBlue}" />

                                            <HorizontalStackLayout Spacing="8"
                                                                     Margin="0,6,0,0"
                                                                     IsVisible="{Binding OffersUpdateActions}">
                                                <Button Text="{Binding UpdateNowText}"
                                                        FontSize="11"
                                                        HeightRequest="28"
                                                        MinimumHeightRequest="28"
                                                        Padding="10,0"
                                                        Margin="0"
                                                        BackgroundColor="{DynamicResource ActionBlue}"
                                                        TextColor="{DynamicResource White}"
                                                        CornerRadius="6"
                                                        Clicked="OnUpdateNotificationNowClicked" />
                                                <Button Text="{Binding UpdateLaterText}"
                                                        FontSize="11"
                                                        HeightRequest="28"
                                                        MinimumHeightRequest="28"
                                                        Padding="10,0"
                                                        Margin="0"
                                                        BackgroundColor="{DynamicResource BackgroundTertiary}"
                                                        TextColor="{DynamicResource LabelSecondary}"
                                                        CornerRadius="6"
                                                        Clicked="OnUpdateNotificationLaterClicked" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <!-- Ghost icon (same pattern as HomeView process row actions) -->
                                        <Border Grid.Column="2"
                                                Background="Transparent"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 0"
                                                WidthRequest="24"
                                                HeightRequest="24"
                                                Padding="0"
                                                Margin="0"
                                                VerticalOptions="Center">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnDismissClicked" />
                                            </Border.GestureRecognizers>
                                            <Image Source="{Binding DismissIconSource, Source={x:Reference RootView}}"
                                                   Aspect="AspectFit"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>
                                    </Grid>

                                    <BoxView Grid.Row="1"
                                             HeightRequest="1"
                                             Color="{DynamicResource Separator}"
                                             Margin="0,0,0,8" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <VerticalStackLayout IsVisible="{Binding IsEmptyVisible}"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="5"
                                         Margin="24">
                        <Label x:Name="EmptyTitleLabel"
                               Text="No notifications"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource LabelPrimary}"
                               HorizontalOptions="Center" />
                        <Label x:Name="EmptyMessageLabel"
                               Text="New ASLM events will appear here."
                               FontSize="12"
                               TextColor="{DynamicResource LabelSecondary}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Footer: total count -->
                <Grid Grid.Row="3"
                      RowDefinitions="Auto, Auto">
                    <BoxView Grid.Row="0"
                             HeightRequest="2"
                             Color="{DynamicResource Separator}"
                             Margin="0,8,0,4"/>
                    <Label Grid.Row="1"
                           Text="{Binding SummaryText}"
                           FontSize="11"
                           TextColor="{DynamicResource LabelSecondary}"
                           HorizontalTextAlignment="End"
                           VerticalTextAlignment="Center" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentView>
