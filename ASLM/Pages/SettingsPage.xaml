<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.SettingsPage"
             Title="Settings"
             BackgroundColor="#1E1E1E">

    <Grid ColumnDefinitions="220, *">

        <!-- Left Sidebar Navigation -->
        <VerticalStackLayout Grid.Column="0"
                             BackgroundColor="#252526"
                             Padding="12" Spacing="4">
            <Label Text="Settings"
                   FontSize="20" FontAttributes="Bold"
                   TextColor="White"
                   Margin="4,8,0,16" />

            <Button x:Name="NavUserProfile"
                    Text="User Profile"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="13"
                    HeightRequest="36"
                    HorizontalOptions="Fill"

                    Clicked="OnUserProfileClicked" />

            <Button x:Name="NavPorts"
                    Text="Ports"
                    BackgroundColor="Transparent"
                    TextColor="#888"
                    FontSize="13"
                    HeightRequest="36"
                    HorizontalOptions="Fill"

                    Clicked="OnPortsClicked" />

            <!-- Spacer -->
            <BoxView HeightRequest="1" Color="#333"
                     Margin="0,12,0,12" />

            <!-- Bottom buttons -->
            <Button Text="← Back"
                    BackgroundColor="Transparent"
                    TextColor="#888"
                    FontSize="13"
                    HeightRequest="36"
                    HorizontalOptions="Fill"

                    Clicked="OnCancelClicked" />
        </VerticalStackLayout>

        <!-- Main Content Area -->
        <ScrollView x:Name="SettingsScroll" Grid.Column="1" Padding="30">
            <VerticalStackLayout Spacing="24">

                <!-- User Profile -->
                <Border x:Name="UserProfileSection"
                        BackgroundColor="#2D2D30"
                        Stroke="#3F3F46" StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="User Profile" FontSize="18" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Display Name" FontSize="12" TextColor="#AAA" />
                        <Entry x:Name="UsernameEntry"
                               FontSize="14" TextColor="White"
                               BackgroundColor="#1E1E1E" />
                    </VerticalStackLayout>
                </Border>

                <!-- Port Allocation -->
                <Border x:Name="PortsSection"
                        BackgroundColor="#2D2D30"
                        Stroke="#3F3F46" StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Port Allocation" FontSize="18" FontAttributes="Bold" TextColor="White" />

                        <Label Text="Official modules start port (100 ports reserved)" FontSize="12" TextColor="#AAA" />
                        <Entry x:Name="OfficialPortEntry"
                               Keyboard="Numeric"
                               FontSize="14" TextColor="White"
                               BackgroundColor="#1E1E1E" />

                        <Label Text="Third-party modules start port (1000 ports reserved)" FontSize="12" TextColor="#AAA" />
                        <Entry x:Name="ThirdPartyPortEntry"
                               Keyboard="Numeric"
                               FontSize="14" TextColor="White"
                               BackgroundColor="#1E1E1E" />

                        <Label x:Name="PortErrorLabel"
                               Text=""
                               FontSize="12" TextColor="#E74C3C"
                               IsVisible="False" />
                    </VerticalStackLayout>
                </Border>

                <!-- Save Button -->
                <Button Text="Save"
                        BackgroundColor="#0078D4"
                        TextColor="White"
                        FontSize="14"
                        WidthRequest="120"
                        HorizontalOptions="End"
                        Clicked="OnSaveClicked" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
