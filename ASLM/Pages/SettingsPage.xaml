<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.SettingsPage"
             Title="Settings"
             BackgroundColor="#000000">

    <Grid ColumnDefinitions="220, *">

        <!-- Left Sidebar Navigation -->
        <VerticalStackLayout Grid.Column="0"
                             BackgroundColor="#1D1D1F"
                             Padding="12" Spacing="4">
            <Label Text="Settings"
                   FontSize="20" FontAttributes="Bold"
                   TextColor="White"
                   Margin="4,8,0,16" />

            <Button x:Name="NavUserProfile"
                    Style="{StaticResource SidebarButton}"
                    Text="User Profile"
                    TextColor="White"
                    Clicked="OnUserProfileClicked" />

            <Button x:Name="NavPorts"
                    Style="{StaticResource SidebarButton}"
                    Text="Ports"
                    Clicked="OnPortsClicked" />

            <!-- Spacer -->
            <BoxView HeightRequest="1" Color="#3A3A3C"
                     Margin="0,12,0,12" />

            <!-- Bottom buttons -->
            <Button Text="← Back"
                    Style="{StaticResource SidebarButton}"
                    Clicked="OnCancelClicked" />
        </VerticalStackLayout>

        <!-- Main Content Area -->
        <ScrollView x:Name="SettingsScroll" Grid.Column="1" Padding="16">
            <VerticalStackLayout Spacing="24">

                <!-- User Profile -->
                <Border x:Name="UserProfileSection"
                        BackgroundColor="#1D1D1F"
                        Stroke="#3A3A3C" StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="User Profile" FontSize="18" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Display Name" FontSize="12" TextColor="#8E8E93" />
                        <Entry x:Name="UsernameEntry"
                               FontSize="14" TextColor="White"
                               BackgroundColor="#000000" />
                    </VerticalStackLayout>
                </Border>

                <!-- Port Allocation -->
                <Border x:Name="PortsSection"
                        BackgroundColor="#1D1D1F"
                        Stroke="#3A3A3C" StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Port Allocation" FontSize="18" FontAttributes="Bold" TextColor="White" />

                        <Label Text="Official modules start port (100 ports reserved)" FontSize="12" TextColor="#8E8E93" />
                        <Entry x:Name="OfficialPortEntry"
                               Keyboard="Numeric"
                               FontSize="14" TextColor="White"
                               BackgroundColor="#000000" />

                        <Label Text="Third-party modules start port (1000 ports reserved)" FontSize="12" TextColor="#8E8E93" />
                        <Entry x:Name="ThirdPartyPortEntry"
                               Keyboard="Numeric"
                               FontSize="14" TextColor="White"
                               BackgroundColor="#000000" />

                        <Label x:Name="PortErrorLabel"
                               Text=""
                               FontSize="12" TextColor="#FF3B30"
                               IsVisible="False" />
                    </VerticalStackLayout>
                </Border>

                <!-- Save Button -->
                <Button Text="Save"
                        BackgroundColor="#007AFF"
                        TextColor="White"
                        FontSize="14"
                        WidthRequest="120"
                        HorizontalOptions="End"
                        Clicked="OnSaveClicked" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
