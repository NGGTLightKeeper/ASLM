<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.LoadingPage"
             BackgroundColor="{DynamicResource BackgroundPrimary}">
    <Grid>
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
            <ActivityIndicator IsRunning="True" Color="{DynamicResource Primary}" />
            <Label Text="Loading..." HorizontalOptions="Center" Style="{StaticResource Body1}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
