<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:ASLM.Services"
             x:Class="ASLM.Pages.SetupWizardPage"
             x:Name="RootView"
             Title="ASLM Setup"
             BackgroundColor="{DynamicResource BackgroundPrimary}">

    <Grid>
        <Grid RowDefinitions="Auto, *, Auto" Padding="16">

        <!-- Header (hidden on welcome step) -->
        <Grid x:Name="HeaderRow" Grid.Row="0" ColumnDefinitions="*, Auto"
              Margin="0,0,0,16" IsVisible="False">
            <VerticalStackLayout Grid.Column="0" Spacing="5">
                <Label x:Name="HeaderTitleLabel"
                       Text="ASLM Setup"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource LabelPrimary}" />
                <Label x:Name="StepLabel"
                       Text="Step 1 of 3 - User Profile"
                       FontSize="14"
                       TextColor="{DynamicResource LabelSecondary}" />
            </VerticalStackLayout>
            <Button x:Name="ToggleLogButton"
                    Grid.Column="1"
                    Text="Show Log"
                    BackgroundColor="{DynamicResource SystemGray4}"
                    TextColor="{DynamicResource LabelSecondary}"
                    FontSize="12"
                    HeightRequest="30"
                    WidthRequest="120"
                    VerticalOptions="End"
                    IsVisible="False"
                    Clicked="OnToggleLogClicked" />
        </Grid>

        <!-- Step Content -->
        <Grid Grid.Row="1">

            <!-- Step 0: Welcome -->
            <VerticalStackLayout x:Name="Step0Panel" IsVisible="True"
                                 VerticalOptions="Center" HorizontalOptions="Center"
                                 Spacing="8">
                <Label x:Name="WelcomeTitleLabel"
                       Text="Welcome to ASLM!"
                       FontSize="36"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource LabelPrimary}"
                       HorizontalTextAlignment="Center" />
                <Label x:Name="WelcomeSubtitleLabel"
                       Text="Advanced System Language Models"
                       FontSize="16"
                       TextColor="{DynamicResource LabelSecondary}"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,24" />
                <Button x:Name="SetupButton"
                        Text="Setup"
                        BackgroundColor="{DynamicResource ActionBlue}"
                        TextColor="{DynamicResource White}"
                        FontSize="16"
                        HeightRequest="48"
                        WidthRequest="280"
                        HorizontalOptions="Center"
                        Clicked="OnSetupClicked" />
                <Button x:Name="FastSetupButton"
                        Text="Fast Setup"
                        BackgroundColor="{DynamicResource SystemGray4}"
                        TextColor="{DynamicResource LabelPrimary}"
                        FontSize="16"
                        HeightRequest="48"
                        WidthRequest="280"
                        HorizontalOptions="Center"
                        Clicked="OnFastSetupClicked" />
                <Label x:Name="FastSetupHintLabel"
                       Text="Fast Setup uses your Windows username and default ports"
                       FontSize="12"
                       TextColor="{DynamicResource LabelSecondary}"
                       HorizontalTextAlignment="Center"
                       Margin="0,4,0,0" />
            </VerticalStackLayout>

            <!-- Step 1: User Profile -->
            <VerticalStackLayout x:Name="Step1Panel" IsVisible="False" Spacing="15"
                                 VerticalOptions="Center" HorizontalOptions="Center"
                                 WidthRequest="400">
                <Label x:Name="DisplayNameTitleLabel"
                       Text="Choose a display name"
                       FontSize="16"
                       TextColor="{DynamicResource LabelPrimary}" />
                <Entry x:Name="UsernameEntry"
                       Placeholder="Your name"
                       FontSize="16"
                       TextColor="{DynamicResource LabelPrimary}"
                       PlaceholderColor="{DynamicResource PlaceholderText}"
                       BackgroundColor="{DynamicResource BackgroundSecondary}" />
            </VerticalStackLayout>

            <!-- Step 2: Port Configuration -->
            <VerticalStackLayout x:Name="Step2Panel" IsVisible="False" Spacing="15"
                                 VerticalOptions="Center" HorizontalOptions="Center"
                                 WidthRequest="400">
                <Label x:Name="PortAllocationTitleLabel"
                       Text="Port Allocation"
                       FontSize="18"
                       TextColor="{DynamicResource LabelPrimary}" />
                <Label x:Name="ModulePortLabel"
                       Text="Module start port"
                       FontSize="13"
                       TextColor="{DynamicResource LabelSecondary}" />
                <Entry x:Name="ModulePortEntry"
                       Text="20000"
                       Keyboard="Numeric"
                       FontSize="16"
                       TextColor="{DynamicResource LabelPrimary}"
                       BackgroundColor="{DynamicResource BackgroundSecondary}" />
                <Label x:Name="PortErrorLabel"
                       Text=""
                       FontSize="12"
                       TextColor="{DynamicResource ActionRed}"
                       IsVisible="False" />
            </VerticalStackLayout>

            <!-- Step 3: Module Selection + Install -->
            <Grid x:Name="Step3Panel" IsVisible="False"
                  RowDefinitions="Auto, *">

                <!-- Module selection list -->
                <ScrollView x:Name="ModuleListScroll" Grid.Row="1">
                    <VerticalStackLayout x:Name="ModuleList" Spacing="8" />
                </ScrollView>

                <!-- Install view (progress + log) -->
                <Grid x:Name="InstallPanel" Grid.Row="0" Grid.RowSpan="2"
                      IsVisible="False"
                      RowDefinitions="Auto, Auto, Auto, Auto, Auto, *">

                    <!-- Current operation -->
                    <Label x:Name="InstallStatusLabel"
                           Text="Preparing..."
                           FontSize="14"
                           TextColor="{DynamicResource LabelPrimary}"
                           Grid.Row="0"
                           Margin="0,0,0,8" />

                    <!-- Overall progress bar -->
                    <Label x:Name="OverallProgressLabel"
                           Text="Overall Progress"
                           FontSize="12"
                           TextColor="{DynamicResource LabelSecondary}"
                           Grid.Row="1"
                           Margin="0,0,0,4" />
                    <ProgressBar x:Name="InstallProgress"
                                 Grid.Row="2"
                                 Progress="0"
                                 ProgressColor="{DynamicResource ActionBlue}"
                                 HeightRequest="6"
                                 Margin="0,0,0,8" />

                    <!-- File download progress bar -->
                    <Label x:Name="DownloadDetailLabel"
                           Text=""
                           FontSize="10"
                           TextColor="{DynamicResource LabelSecondary}"
                           Grid.Row="3"
                           Margin="0,0,0,4" />
                    <ProgressBar x:Name="FileProgress"
                                 Grid.Row="4"
                                 Progress="0"
                                 ProgressColor="{DynamicResource ActionGreen}"
                                 HeightRequest="4"
                                 Margin="0,0,0,8" />

                    <Border Grid.Row="5"
                            BackgroundColor="{DynamicResource BackgroundSecondary}"
                            Stroke="{DynamicResource Separator}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="8"
                            IsVisible="{Binding IsInstallLogVisible, Source={x:Reference RootView}}"
                            Margin="0,8,0,0">
                        <services:ConsoleOutputView x:Name="InstallLogConsole"
                                                    Text="{Binding InstallLogText, Source={x:Reference RootView}}"
                                                    SessionKey="{Binding InstallLogSessionKey, Source={x:Reference RootView}}"
                                                    HorizontalOptions="Fill"
                                                    VerticalOptions="Fill" />
                    </Border>
                </Grid>
            </Grid>

        </Grid>

        <!-- Navigation Buttons (hidden on step 0) -->
        <HorizontalStackLayout x:Name="ButtonPanel" Grid.Row="2" Spacing="12"
                               HorizontalOptions="End"
                               Margin="0,20,0,0"
                               IsVisible="False">
            <Button x:Name="BackButton"
                    Text="Back"
                    BackgroundColor="{DynamicResource SystemGray4}"
                    TextColor="{DynamicResource LabelPrimary}"
                    FontSize="14"
                    WidthRequest="100"
                    IsVisible="False"
                    Clicked="OnBackClicked" />
            <Button x:Name="NextButton"
                    Text="Next"
                    BackgroundColor="{DynamicResource ActionBlue}"
                    TextColor="{DynamicResource White}"
                    FontSize="14"
                    WidthRequest="100"
                    Clicked="OnNextClicked" />
        </HorizontalStackLayout>

        </Grid>

        <ContentView x:Name="OverlayContainer"
                     IsVisible="False"
                     BackgroundColor="Transparent" />
    </Grid>

</ContentPage>
