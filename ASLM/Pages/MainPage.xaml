<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.MainPage"
             Title="ASLM"
             BackgroundColor="#1E1E1E">

    <Grid ColumnDefinitions="Auto, *">

        <!-- Left Sidebar -->
        <Grid x:Name="SidePanel" Grid.Column="0"
              WidthRequest="220"
              RowDefinitions="Auto, Auto, *, Auto"
              BackgroundColor="#252526"
              Padding="8">

            <!-- Collapse Toggle -->
            <Button x:Name="CollapseButton"
                    Grid.Row="0"
                    Text="◀"
                    BackgroundColor="Transparent"
                    TextColor="#888"
                    FontSize="12"
                    HeightRequest="28"
                    WidthRequest="28"
                    HorizontalOptions="End"
                    Clicked="OnCollapseClicked" />

            <!-- Home Button -->
            <Button x:Name="HomeButton"
                    Grid.Row="1"
                    Text="🏠  Home"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="13"
                    HeightRequest="36"
                    HorizontalOptions="Fill"

                    Clicked="OnHomeClicked" />

            <!-- Module Pages -->
            <ScrollView Grid.Row="2" Margin="0,8,0,0">
                <VerticalStackLayout Spacing="2">
                    <Label x:Name="PagesHeader" Text="PAGES"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#555" Margin="8,4,0,6" />
                    <VerticalStackLayout x:Name="ModulePagePanel" Spacing="2" />
                </VerticalStackLayout>
            </ScrollView>

            <!-- Settings Button -->
            <Button x:Name="SettingsButton" Grid.Row="3"
                    Text="⚙  Settings"
                    BackgroundColor="Transparent"
                    TextColor="#888"
                    FontSize="13"
                    HeightRequest="36"
                    Margin="0,4,0,0"
                    HorizontalOptions="Fill"

                    Clicked="OnSettingsClicked" />
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">

            <!-- Module Dashboard (Home view) -->
            <ScrollView x:Name="DashboardView" IsVisible="True" Padding="30">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Modules"
                           FontSize="24" FontAttributes="Bold"
                           TextColor="White" />
                    <Label x:Name="DashboardSubtitle"
                           Text="Manage your installed modules"
                           FontSize="13" TextColor="#888"
                           Margin="0,0,0,8" />
                    <!-- Module cards grid -->
                    <FlexLayout x:Name="ModuleCardsPanel"
                                Wrap="Wrap"
                                Direction="Row"
                                AlignContent="Start"
                                JustifyContent="Start" />
                </VerticalStackLayout>
            </ScrollView>

            <!-- WebView (visible when a module page is selected) -->
            <WebView x:Name="Browser"
                     IsVisible="False"
                     Navigating="Browser_Navigating" />

        </Grid>

    </Grid>

</ContentPage>
