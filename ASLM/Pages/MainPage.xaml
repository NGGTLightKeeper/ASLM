<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.MainPage"
             Title="ASLM"
             BackgroundColor="#000000">

    <Grid ColumnDefinitions="Auto, *">

        <!-- Left Sidebar -->
        <Grid x:Name="SidePanel" Grid.Column="0"
              WidthRequest="220"
              RowDefinitions="Auto, *, Auto"
              BackgroundColor="#1D1D1F"
              Padding="8">

            <!-- Collapse Toggle (fixed top) -->
            <Button x:Name="CollapseButton"
                    Grid.Row="0"
                    Style="{StaticResource SidebarButton}"
                    TextColor="#8E8E93"
                    HeightRequest="36"
                    HorizontalOptions="Fill"
                    Clicked="OnCollapseClicked" />

            <!-- Scrollable nav list: Home + Module Pages -->
            <ScrollView Grid.Row="1" Margin="0,4,0,0">
                <VerticalStackLayout x:Name="ModulePagePanel" Spacing="2" />
            </ScrollView>

            <!-- Settings Button (fixed bottom) -->
            <Button x:Name="SettingsButton" Grid.Row="2"
                    Style="{StaticResource SidebarButton}"
                    Text="Settings"
                    HeightRequest="36"
                    HorizontalOptions="Fill"
                    Margin="0,4,0,0"
                    Clicked="OnSettingsClicked" />
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">

            <!-- Module Dashboard (Home view) -->
            <CollectionView x:Name="DashboardView"
                            IsVisible="True"
                            Margin="12,16"
                            ItemsSource="{Binding Modules}"
                            SelectionMode="None">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="{Binding GridSpan}"
                                     VerticalItemSpacing="4"
                                     HorizontalItemSpacing="4" />
                </CollectionView.ItemsLayout>

                <CollectionView.Header>
                    <VerticalStackLayout Spacing="16" Margin="4,0,4,16">
                        <Label Text="Modules"
                               FontSize="24" FontAttributes="Bold"
                               TextColor="White" />
                        <Label x:Name="DashboardSubtitle"
                               Text="Manage your installed modules"
                               FontSize="14" TextColor="#8E8E93"
                               Margin="0,0,0,8" />
                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.EmptyView>
                    <Label Text="No modules found. Install modules via the Setup Wizard."
                           FontSize="14"
                           TextColor="#8E8E93"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Margin="0,20,0,0" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#1D1D1F"
                                Stroke="#3A3A3C"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="0">

                            <Grid ColumnDefinitions="Auto, *">
                                <!-- Icon -->
                                <Border Grid.Column="0"
                                        IsVisible="{Binding HasIcon}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 0"
                                        BackgroundColor="#1D1D1F"
                                        WidthRequest="164"
                                        HeightRequest="164"
                                        Padding="0"
                                        Margin="8,8,0,8">
                                    <Image Source="{Binding IconFullPath}"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Fill"
                                           VerticalOptions="Fill" />
                                </Border>

                                <!-- Right side: Text + Buttons -->
                                <Grid Grid.Column="1"
                                      RowDefinitions="*, Auto"
                                      Padding="8">

                                    <!-- Text area (top) -->
                                    <VerticalStackLayout Grid.Row="0" Spacing="2">
                                        <Label Text="{Binding Name}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="White" />
                                        <Label Text="{Binding VersionString}"
                                               FontSize="14"
                                               TextColor="#8E8E93" />
                                    </VerticalStackLayout>

                                    <!-- Action buttons (bottom) -->

                                    <!-- Running: Stop + Restart -->
                                    <Grid Grid.Row="1"
                                          ColumnDefinitions="*, *"
                                          ColumnSpacing="8"
                                          IsVisible="{Binding IsRunning}">
                                        <Button Grid.Column="0"
                                                Text="⏹ Stop"
                                                Command="{Binding StopCommand}"
                                                BackgroundColor="#4CD964"
                                                TextColor="White"
                                                FontSize="12"
                                                HeightRequest="24"
                                                CornerRadius="4"
                                                HorizontalOptions="Fill" />
                                        <Button Grid.Column="1"
                                                Text="🔄 Restart"
                                                Command="{Binding RestartCommand}"
                                                BackgroundColor="#3A3A3C"
                                                TextColor="White"
                                                FontSize="12"
                                                HeightRequest="24"
                                                CornerRadius="4"
                                                HorizontalOptions="Fill" />
                                    </Grid>

                                    <!-- Stopped: Launch -->
                                    <Button Grid.Row="1"
                                            Text="▶ Launch"
                                            Command="{Binding LaunchCommand}"
                                            IsVisible="{Binding IsStopped}"
                                            BackgroundColor="#007AFF"
                                            TextColor="White"
                                            FontSize="12"
                                            HeightRequest="24"
                                            CornerRadius="4"
                                            HorizontalOptions="Fill"
                                            Margin="0" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- WebView (visible when a module page is selected) -->
            <WebView x:Name="Browser"
                     IsVisible="False"
                     Navigating="Browser_Navigating" />

        </Grid>

    </Grid>

</ContentPage>
