<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.MainPage"
             Title="ASLM"
             BackgroundColor="#1E1E1E">

    <Grid ColumnDefinitions="Auto, *">

        <!-- Left Sidebar -->
        <Grid x:Name="SidePanel" Grid.Column="0"
              WidthRequest="220"
              RowDefinitions="Auto, Auto, *, Auto"
              BackgroundColor="#252526"
              Padding="8">

            <!-- Collapse Toggle -->
            <Button x:Name="CollapseButton"
                    Grid.Row="0"
                    Text="◀"
                    BackgroundColor="Transparent"
                    TextColor="#888"
                    FontSize="12"
                    HeightRequest="28"
                    WidthRequest="28"
                    HorizontalOptions="End"
                    Clicked="OnCollapseClicked" />

            <!-- Home Button -->
            <Button x:Name="HomeButton"
                    Grid.Row="1"
                    Text="🏠  Home"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="13"
                    HeightRequest="36"
                    HorizontalOptions="Fill"

                    Clicked="OnHomeClicked" />

            <!-- Module Pages -->
            <ScrollView Grid.Row="2" Margin="0,8,0,0">
                <VerticalStackLayout Spacing="2">
                    <Label x:Name="PagesHeader" Text="PAGES"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#555" Margin="8,4,0,6" />
                    <VerticalStackLayout x:Name="ModulePagePanel" Spacing="2" />
                </VerticalStackLayout>
            </ScrollView>

            <!-- Settings Button -->
            <Button x:Name="SettingsButton" Grid.Row="3"
                    Text="⚙  Settings"
                    BackgroundColor="Transparent"
                    TextColor="#888"
                    FontSize="13"
                    HeightRequest="36"
                    Margin="0,4,0,0"
                    HorizontalOptions="Fill"

                    Clicked="OnSettingsClicked" />
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">

            <!-- Module Dashboard (Home view) -->
            <CollectionView x:Name="DashboardView"
                            IsVisible="True"
                            Margin="30"
                            ItemsSource="{Binding Modules}"
                            SelectionMode="None">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="{Binding GridSpan}"
                                     VerticalItemSpacing="10"
                                     HorizontalItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.Header>
                    <VerticalStackLayout Spacing="16" Margin="0,0,0,20">
                        <Label Text="Modules"
                               FontSize="24" FontAttributes="Bold"
                               TextColor="White" />
                        <Label x:Name="DashboardSubtitle"
                               Text="Manage your installed modules"
                               FontSize="13" TextColor="#888"
                               Margin="0,0,0,8" />
                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.EmptyView>
                    <Label Text="No modules found. Install modules via the Setup Wizard."
                           FontSize="14"
                           TextColor="#888"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Margin="0,20,0,0" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#2D2D30"
                                Stroke="#3F3F46"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="0"
                                HeightRequest="180">

                            <Grid ColumnDefinitions="Auto, *">
                                <!-- Icon -->
                                <Border Grid.Column="0"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 0"
                                        BackgroundColor="#252526"
                                        WidthRequest="164"
                                        HeightRequest="164"
                                        Padding="0"
                                        Margin="8,8,0,8">
                                    <Image Source="{Binding IconFullPath}"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Fill"
                                           VerticalOptions="Fill" />
                                </Border>

                                <!-- Right side: Text + Buttons -->
                                <Grid Grid.Column="1"
                                      RowDefinitions="*, Auto"
                                      Padding="8">

                                    <!-- Text area (top) -->
                                    <VerticalStackLayout Grid.Row="0" Spacing="2">
                                        <Label Text="{Binding Name}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="White" />
                                        <Label Text="{Binding VersionString}"
                                               FontSize="14"
                                               TextColor="#888" />
                                    </VerticalStackLayout>

                                    <!-- Action buttons (bottom) -->

                                    <!-- Running: Stop + Restart -->
                                    <Grid Grid.Row="1"
                                          ColumnDefinitions="*, *"
                                          ColumnSpacing="8"
                                          IsVisible="{Binding IsRunning}">
                                        <Button Grid.Column="0"
                                                Text="⏹ Stop"
                                                Command="{Binding StopCommand}"
                                                BackgroundColor="#8B0000"
                                                TextColor="White"
                                                FontSize="12"
                                                HeightRequest="24"
                                                CornerRadius="4"
                                                HorizontalOptions="Fill" />
                                        <Button Grid.Column="1"
                                                Text="🔄 Restart"
                                                Command="{Binding RestartCommand}"
                                                BackgroundColor="#333"
                                                TextColor="White"
                                                FontSize="12"
                                                HeightRequest="24"
                                                CornerRadius="4"
                                                HorizontalOptions="Fill" />
                                    </Grid>

                                    <!-- Stopped: Launch -->
                                    <Button Grid.Row="1"
                                            Text="▶ Launch"
                                            Command="{Binding LaunchCommand}"
                                            IsVisible="{Binding IsStopped}"
                                            BackgroundColor="#0078D4"
                                            TextColor="White"
                                            FontSize="12"
                                            HeightRequest="24"
                                            CornerRadius="4"
                                            HorizontalOptions="Fill"
                                            Margin="0" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- WebView (visible when a module page is selected) -->
            <WebView x:Name="Browser"
                     IsVisible="False"
                     Navigating="Browser_Navigating" />

        </Grid>

    </Grid>

</ContentPage>
