<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.HomeView"
             x:Name="Root">

    <ContentView.Resources>
        <Style x:Key="HomeHeaderTitleLabel" TargetType="Label">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="MaxLines" Value="1" />
            <Setter Property="LineBreakMode" Value="TailTruncation" />
            <Setter Property="TextColor" Value="{DynamicResource LabelPrimary}" />
        </Style>

    </ContentView.Resources>

    <Grid RowDefinitions="Auto,Auto,*"
          RowSpacing="12"
          Margin="0,0,0,4">

        <VerticalStackLayout Grid.Row="0"
                             Spacing="0"
                             Margin="0"
                             Padding="4">
            <Label x:Name="HomeTitleLabel"
                   Text="Home"
                   Style="{StaticResource HomeHeaderTitleLabel}" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        Margin="0"
                        ItemsSource="{Binding SummaryCards}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="{Binding BindingContext.SummaryGridSpan, Source={x:Reference Root}}"
                                 VerticalItemSpacing="0"
                                 HorizontalItemSpacing="4" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{DynamicResource BackgroundSecondary}"
                            Stroke="{DynamicResource Separator}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="8">
                        <Grid RowDefinitions="Auto,Auto"
                              RowSpacing="8">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8">
                                <VerticalStackLayout Spacing="0">
                                    <Label Text="{Binding Title}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource LabelPrimary}"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>

                                <Label Grid.Column="1"
                                       Text="{Binding StatusText}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource LabelPrimary}"
                                       VerticalOptions="Start" />
                            </Grid>

                            <VerticalStackLayout Grid.Row="1"
                                                 Spacing="6"
                                                 BindableLayout.ItemsSource="{Binding Metrics}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid RowDefinitions="Auto,Auto"
                                              RowSpacing="3">
                                            <Grid ColumnDefinitions="64,*,Auto"
                                                  ColumnSpacing="8">
                                                <Label Text="{Binding Name}"
                                                       FontSize="12"
                                                       TextColor="{DynamicResource LabelSecondary}"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding DetailText}"
                                                       FontSize="12"
                                                       TextColor="{DynamicResource LabelSecondary}"
                                                       LineBreakMode="TailTruncation"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="2"
                                                       Text="{Binding ValueText}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="{DynamicResource LabelPrimary}"
                                                       VerticalOptions="Center" />
                                            </Grid>

                                            <ProgressBar Grid.Row="1"
                                                         Progress="{Binding ProgressValue}"
                                                         ProgressColor="{Binding AccentColor}"
                                                         BackgroundColor="{DynamicResource BackgroundTertiary}"
                                                         HeightRequest="4"
                                                         IsVisible="{Binding HasProgress}" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid x:Name="WorkspaceLayout"
              Grid.Row="2"
              Margin="4,0"
              ColumnSpacing="8"
              RowSpacing="8">
            <Border x:Name="ProcessTreePanel"
                    BackgroundColor="{DynamicResource BackgroundSecondary}"
                    Stroke="{DynamicResource Separator}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="0">
                <Grid RowDefinitions="Auto,Auto,*">
                    <VerticalStackLayout Grid.Row="0"
                                         Spacing="0"
                                         Padding="8">
                        <Label x:Name="ManagedProcessesHeaderLabel"
                               Text="Managed Processes"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource LabelPrimary}" />
                    </VerticalStackLayout>

                    <Grid Grid.Row="1"
                          ColumnSpacing="0"
                          Padding="0"
                          BackgroundColor="{DynamicResource BackgroundTertiary}"
                          HeightRequest="30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="88" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="88" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="72" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="1.25*" />
                        </Grid.ColumnDefinitions>

                        <Label x:Name="ColumnNameLabel"
                               Text="Name"
                               FontSize="12"
                               TextColor="{DynamicResource LabelSecondary}"
                               Padding="8,0"
                               VerticalOptions="Center" />
                        <BoxView Grid.Column="1"
                                 BackgroundColor="{DynamicResource Separator}" />
                        <Label x:Name="ColumnCpuLabel"
                               Grid.Column="2"
                               Text="CPU"
                               FontSize="12"
                               TextColor="{DynamicResource LabelSecondary}"
                               Padding="8,0"
                               HorizontalTextAlignment="End"
                               VerticalOptions="Center" />
                        <BoxView Grid.Column="3"
                                 BackgroundColor="{DynamicResource Separator}" />
                        <Label x:Name="ColumnGpuLabel"
                               Grid.Column="4"
                               Text="GPU"
                               FontSize="12"
                               TextColor="{DynamicResource LabelSecondary}"
                               Padding="8,0"
                               HorizontalTextAlignment="End"
                               VerticalOptions="Center" />
                        <BoxView Grid.Column="5"
                                 BackgroundColor="{DynamicResource Separator}" />
                        <Label x:Name="ColumnRamLabel"
                               Grid.Column="6"
                               Text="RAM"
                               FontSize="12"
                               TextColor="{DynamicResource LabelSecondary}"
                               Padding="8,0"
                               HorizontalTextAlignment="End"
                               VerticalOptions="Center" />
                        <BoxView Grid.Column="7"
                                 BackgroundColor="{DynamicResource Separator}" />
                        <Label x:Name="ColumnDiskLabel"
                               Grid.Column="8"
                               Text="Disk"
                               FontSize="12"
                               TextColor="{DynamicResource LabelSecondary}"
                               Padding="8,0"
                               HorizontalTextAlignment="End"
                               VerticalOptions="Center" />
                        <BoxView Grid.Column="9"
                                 BackgroundColor="{DynamicResource Separator}" />
                        <Label x:Name="ColumnNetLabel"
                               Grid.Column="10"
                               Text="Net"
                               FontSize="12"
                               TextColor="{DynamicResource LabelSecondary}"
                               Padding="8,0"
                               HorizontalTextAlignment="End"
                               VerticalOptions="Center" />
                        <BoxView Grid.Column="11"
                                 BackgroundColor="{DynamicResource Separator}" />
                        <Label x:Name="ColumnDetailsLabel"
                               Grid.Column="12"
                               Text="Details"
                               FontSize="12"
                               TextColor="{DynamicResource LabelSecondary}"
                               Padding="8,0"
                               VerticalOptions="Center" />
                    </Grid>

                    <CollectionView Grid.Row="2"
                                    ItemsSource="{Binding ProcessNodes}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical"
                                               ItemSpacing="0" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid RowDefinitions="Auto,1">
                                    <Grid Grid.Row="0"
                                          ColumnSpacing="0"
                                          MinimumHeightRequest="32">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="1" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="1" />
                                            <ColumnDefinition Width="88" />
                                            <ColumnDefinition Width="1" />
                                            <ColumnDefinition Width="88" />
                                            <ColumnDefinition Width="1" />
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="1" />
                                            <ColumnDefinition Width="1.25*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid ColumnDefinitions="18,*"
                                              ColumnSpacing="4"
                                              Padding="8,0"
                                              Margin="{Binding IndentMargin}"
                                              VerticalOptions="Center">
                                            <Image Source="{Binding ExpanderIconSource}"
                                                   WidthRequest="16"
                                                   HeightRequest="16"
                                                   Aspect="AspectFit"
                                                   IsVisible="{Binding CanExpand}"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Title}"
                                                   FontSize="12"
                                                   FontAttributes="{Binding TitleFontAttributes}"
                                                   TextColor="{Binding TitleColor}"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation" />
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                            </Grid.GestureRecognizers>
                                        </Grid>

                                        <BoxView Grid.Column="1"
                                                 BackgroundColor="{DynamicResource Separator}"
                                                 WidthRequest="1"
                                                 HorizontalOptions="Center" />
                                        <Label Grid.Column="2"
                                               Text="{Binding CpuText}"
                                               FontSize="12"
                                               TextColor="{DynamicResource LabelPrimary}"
                                               Padding="8,0"
                                               HorizontalTextAlignment="End"
                                               VerticalOptions="Center" />
                                        <BoxView Grid.Column="3"
                                                 BackgroundColor="{DynamicResource Separator}"
                                                 WidthRequest="1"
                                                 HorizontalOptions="Center" />
                                        <Label Grid.Column="4"
                                               Text="{Binding GpuText}"
                                               FontSize="12"
                                               TextColor="{DynamicResource LabelPrimary}"
                                               Padding="8,0"
                                               HorizontalTextAlignment="End"
                                               VerticalOptions="Center" />
                                        <BoxView Grid.Column="5"
                                                 BackgroundColor="{DynamicResource Separator}"
                                                 WidthRequest="1"
                                                 HorizontalOptions="Center" />
                                        <Label Grid.Column="6"
                                               Text="{Binding MemoryText}"
                                               FontSize="12"
                                               TextColor="{DynamicResource LabelPrimary}"
                                               Padding="8,0"
                                               HorizontalTextAlignment="End"
                                               VerticalOptions="Center" />
                                        <BoxView Grid.Column="7"
                                                 BackgroundColor="{DynamicResource Separator}"
                                                 WidthRequest="1"
                                                 HorizontalOptions="Center" />
                                        <Label Grid.Column="8"
                                               Text="{Binding DiskText}"
                                               FontSize="12"
                                               TextColor="{DynamicResource LabelPrimary}"
                                               Padding="8,0"
                                               HorizontalTextAlignment="End"
                                               VerticalOptions="Center" />
                                        <BoxView Grid.Column="9"
                                                 BackgroundColor="{DynamicResource Separator}"
                                                 WidthRequest="1"
                                                 HorizontalOptions="Center" />
                                        <Label Grid.Column="10"
                                               Text="{Binding NetworkText}"
                                               FontSize="12"
                                               TextColor="{DynamicResource LabelPrimary}"
                                               Padding="8,0"
                                               HorizontalTextAlignment="End"
                                               VerticalOptions="Center" />
                                        <BoxView Grid.Column="11"
                                                 BackgroundColor="{DynamicResource Separator}"
                                                 WidthRequest="1"
                                                 HorizontalOptions="Center" />
                                        <Label Grid.Column="12"
                                               Text="{Binding DetailsText}"
                                               FontSize="12"
                                               TextColor="{DynamicResource LabelSecondary}"
                                               Padding="8,0"
                                               VerticalOptions="Center"
                                               LineBreakMode="TailTruncation" />
                                    </Grid>

                                    <BoxView Grid.Row="1"
                                             HeightRequest="1"
                                             BackgroundColor="{DynamicResource Separator}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <Border x:Name="ModulesPanel"
                    BackgroundColor="{DynamicResource BackgroundSecondary}"
                    Stroke="{DynamicResource Separator}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <VerticalStackLayout Grid.Row="0"
                                         Spacing="0"
                                         Padding="8">
                        <Label x:Name="ModulesHeaderLabel"
                               Text="Modules"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource LabelPrimary}" />
                    </VerticalStackLayout>

                    <CollectionView x:Name="ModulesCollection"
                                    Grid.Row="1"
                                    ItemsSource="{Binding Modules}"
                                    SelectionMode="None"
                                    Margin="12,0,8,8">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical"
                                               ItemSpacing="0" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid RowDefinitions="Auto,1">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10"
                                          MinimumHeightRequest="48"
                                          Padding="0,4">
                                        <VerticalStackLayout Spacing="2"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="{DynamicResource LabelPrimary}"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding SecondaryText}"
                                                   FontSize="12"
                                                   TextColor="{DynamicResource LabelSecondary}"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>

                                        <Grid Grid.Column="1"
                                              VerticalOptions="Center">
                                            <HorizontalStackLayout Spacing="8"
                                                                   HorizontalOptions="End"
                                                                   IsVisible="{Binding IsRunningAndIdle}">
                                                <Border Background="{SolidColorBrush {DynamicResource ActionRed}}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 4"
                                                        HeightRequest="32"
                                                        WidthRequest="32"
                                                        Padding="8">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding StopCommand}" />
                                                    </Border.GestureRecognizers>
                                                    <Image Source="icon_stop.png"
                                                           WidthRequest="16"
                                                           HeightRequest="16"
                                                           Aspect="AspectFit" />
                                                </Border>
                                                <Border Background="{SolidColorBrush {DynamicResource ActionBlue}}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 4"
                                                        HeightRequest="32"
                                                        WidthRequest="32"
                                                        Padding="8">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding RestartCommand}" />
                                                    </Border.GestureRecognizers>
                                                    <Image Source="icon_restart.png"
                                                           WidthRequest="16"
                                                           HeightRequest="16"
                                                           Aspect="AspectFit" />
                                                </Border>
                                                <Border Background="{SolidColorBrush {DynamicResource SystemGray4}}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 4"
                                                        HeightRequest="32"
                                                        WidthRequest="32"
                                                        Padding="8"
                                                        IsVisible="{Binding IsRunningAndIdle}">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding ManageCommand}" />
                                                    </Border.GestureRecognizers>
                                                    <Image Source="icon_modules.png"
                                                           WidthRequest="16"
                                                           HeightRequest="16"
                                                           Aspect="AspectFit" />
                                                </Border>
                                                <Border Background="{SolidColorBrush {DynamicResource SystemGray3}}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 4"
                                                        HeightRequest="32"
                                                        WidthRequest="32"
                                                        Padding="8"
                                                        IsVisible="{Binding CanOpenConsole}">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding ConsoleCommand}" />
                                                    </Border.GestureRecognizers>
                                                    <Image Source="icon_console.png"
                                                           WidthRequest="16"
                                                           HeightRequest="16"
                                                           Aspect="AspectFit" />
                                                </Border>
                                            </HorizontalStackLayout>

                                            <HorizontalStackLayout Spacing="8"
                                                                   HorizontalOptions="End"
                                                                   IsVisible="{Binding IsStoppedAndIdle}">
                                                <Border Background="{SolidColorBrush {DynamicResource ActionBlue}}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 4"
                                                        HeightRequest="32"
                                                        WidthRequest="32"
                                                        Padding="8">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding LaunchCommand}" />
                                                    </Border.GestureRecognizers>
                                                    <Image Source="icon_play.png"
                                                           WidthRequest="16"
                                                           HeightRequest="16"
                                                           Aspect="AspectFit" />
                                                </Border>
                                                <Border Background="{SolidColorBrush {DynamicResource SystemGray4}}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 4"
                                                        HeightRequest="32"
                                                        WidthRequest="32"
                                                        Padding="8">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding ManageCommand}" />
                                                    </Border.GestureRecognizers>
                                                    <Image Source="icon_modules.png"
                                                           WidthRequest="16"
                                                           HeightRequest="16"
                                                           Aspect="AspectFit" />
                                                </Border>
                                            </HorizontalStackLayout>

                                            <HorizontalStackLayout Spacing="6"
                                                                   HorizontalOptions="End"
                                                                   IsVisible="{Binding IsBusy}">
                                                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                                                   WidthRequest="16"
                                                                   HeightRequest="16"
                                                                   Color="{DynamicResource LabelPrimary}" />
                                               <Label Text="{Binding BusyText}"
                                                      FontSize="12"
                                                      TextColor="{DynamicResource LabelSecondary}"
                                                      VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Grid>
                                    </Grid>

                                    <BoxView Grid.Row="1"
                                             HeightRequest="1"
                                             BackgroundColor="{DynamicResource Separator}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentView>
