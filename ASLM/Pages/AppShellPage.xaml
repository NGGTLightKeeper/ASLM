<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASLM.Pages.AppShellPage"
             Title="ASLM"
             BackgroundColor="{DynamicResource BackgroundPrimary}">

    <Grid ColumnDefinitions="Auto, *">

        <!-- Left Sidebar -->
        <Grid x:Name="SidePanel" Grid.Column="0"
              RowDefinitions="Auto, *, Auto, Auto"
              BackgroundColor="{DynamicResource BackgroundSecondary}"
              Padding="8">

            <!-- Collapse Toggle (fixed top) -->
            <Button x:Name="CollapseButton"
                    Grid.Row="0"
                    Style="{StaticResource SidebarButton}"
                    TextColor="{DynamicResource LabelSecondary}"
                    HeightRequest="36"
                    HorizontalOptions="Fill"
                    Clicked="OnCollapseClicked" />

            <!-- Scrollable nav list: Module Pages (top section) -->
            <ScrollView Grid.Row="1" Margin="0,4,0,0">
                <VerticalStackLayout x:Name="ModulePagePanel" Spacing="2" />
            </ScrollView>

            <!-- Separator -->
            <BoxView Grid.Row="2"
                     HeightRequest="1"
                     Color="{DynamicResource Separator}"
                     Margin="0,4,0,4" />

            <!-- Bottom section: system pages -->
            <VerticalStackLayout Grid.Row="3" Spacing="2">
                <Button x:Name="HomeButton"
                        Style="{StaticResource SidebarButton}"
                        Text="Home"
                        HeightRequest="36"
                        HorizontalOptions="Fill"
                        Clicked="OnNavClicked" />

                <Button x:Name="ConsolesButton"
                        Style="{StaticResource SidebarButton}"
                        Text="Consoles"
                        HeightRequest="36"
                        HorizontalOptions="Fill"
                        Clicked="OnNavClicked" />

                <Button x:Name="ModulesButton"
                        Style="{StaticResource SidebarButton}"
                        Text="Modules"
                        HeightRequest="36"
                        HorizontalOptions="Fill"
                        Clicked="OnNavClicked" />

                <Button x:Name="AslmApiButton"
                        Style="{StaticResource SidebarButton}"
                        Text="ASLM API"
                        HeightRequest="36"
                        HorizontalOptions="Fill"
                        Clicked="OnNavClicked" />

                <Button x:Name="NotificationsButton"
                        Style="{StaticResource SidebarButton}"
                        Text="Notifications"
                        HeightRequest="36"
                        HorizontalOptions="Fill"
                        Clicked="OnNavClicked" />

                <Button x:Name="DownloadsButton"
                        Style="{StaticResource SidebarButton}"
                        Text="Download"
                        HeightRequest="36"
                        HorizontalOptions="Fill"
                        Clicked="OnNavClicked" />

                <Button x:Name="SettingsButton"
                        Style="{StaticResource SidebarButton}"
                        Text="Settings"
                        HeightRequest="36"
                        HorizontalOptions="Fill"
                        Clicked="OnNavClicked" />
            </VerticalStackLayout>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <ContentView x:Name="ContentArea"
                         Padding="8"/>

            <!-- WebView (visible when a module page is selected) -->
            <WebView x:Name="Browser"
                     IsVisible="False"
                     HandlerChanged="Browser_HandlerChanged"
                     Navigating="Browser_Navigating" />
        </Grid>
        
        <!-- Overlay Container -->
        <ContentView x:Name="OverlayContainer"
                     Grid.ColumnSpan="2"
                     IsVisible="False"
                     BackgroundColor="Transparent" />

        <!-- Toasts sit above the shell: outer layer passes pointer through to WebView2 for drag/drop; only the bottom-right stack captures input. -->
        <Grid Grid.ColumnSpan="2"
              RowDefinitions="*,Auto"
              HorizontalOptions="Fill"
              VerticalOptions="Fill"
              InputTransparent="True"
              CascadeInputTransparent="False">
            <BoxView Grid.Row="0"
                     Color="Transparent"
                     InputTransparent="True" />
            <Grid Grid.Row="1"
                  Margin="0,0,16,16"
                  HorizontalOptions="End"
                  VerticalOptions="End"
                  WidthRequest="360"
                  InputTransparent="False">
                <VerticalStackLayout x:Name="ToastPanel"
                                     Spacing="8"
                                     WidthRequest="360"
                                     HorizontalOptions="End"
                                     VerticalOptions="End"
                                     InputTransparent="False" />
            </Grid>
        </Grid>

    </Grid>

</ContentPage>
