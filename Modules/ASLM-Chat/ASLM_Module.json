{
    "fileVersion": 1,
    "id": "aslm-chat",
    "name": "ASLM Chat",
    "description": "ASLM Chat Module",
    "version": "0.4.0.22",
    "author": "NGGT-ASLM",
    "type": "ui",
    "hasPage": true,
    "icon": "icon.png",
    "sidebarIcon": "sidebar_icon.png",
    "source": {
        "type": "github",
        "repo": "NGGTLightKeeper/ASLM-Chat"
    },
    "dependencies": {
        "engines": [
            {
                "id": "python-runtime",
                "libraries": [
                    "argon2-cffi==25.1.0",
                    "aiofiles==24.1.0",
                    "aiohttp==3.11.0",
                    "accelerate==0.30.1",
                    "adblockparser==0.7",
                    "beautifulsoup4==4.12.3",
                    "camoufox==0.4.10",
                    "colorama==0.4.6",
                    "crawl4ai==0.4.0",
                    "cffi==1.17.1",
                    "curl_cffi==0.7.0",
                    "ddgs==9.10.0",
                    "django==6.0.2",
                    "django-cors-headers==4.9.0",
                    "duckduckgo-search==7.0.2",
                    "easyocr==1.7.2",
                    "av==13.1.0",
                    "faster-whisper==1.1.1",
                    "fastapi==0.128.0",
                    "gliner==0.2.22",
                    "gliner2==1.2.5",
                    "httpx==0.28.1",
                    "huggingface_hub==0.23.0",
                    "litellm==1.80.0",
                    "lmstudio==1.5.0",
                    "markdownify==0.11.0",
                    "martor==1.7.16",
                    "mcp==1.26.0",
                    "networkx==3.6.1",
                    "nltk==3.9.2",
                    "nodriver==0.35",
                    "numpy==2.0.0",
                    "google-genai==1.72.0",
                    "openai==2.16.0",
                    "ollama==0.6.1",
                    "pillow==10.4.0",
                    "playwright==1.50.0",
                    "psutil==6.0.0",
                    "pymupdf4llm==0.3.4",
                    "pydantic-settings==2.7.0",
                    "pydantic==2.11.7",
                    "python-dotenv==1.0.1",
                    "pyyaml==6.0.2",
                    "requests==2.32.3",
                    "rich==13.9.4",
                    "scipy==1.17.0",
                    "seleniumbase==4.33.0",
                    "sentence-transformers==5.2.0",
                    "spacy==3.8.11",
                    "tenacity==9.0.0",
                    "torch==2.6.0",
                    "tqdm==4.67.0",
                    "trafilatura==2.0.0",
                    "ultralytics==8.4.21",
                    "uvicorn[standard]==0.40.0",
                    "whitenoise==6.12.0",
                    "youtube-transcript-api==0.6.0",
                    "yt-dlp==2024.3.10"
                ]
            },
            {
                "id": "ollama-service"
            }
        ]
    },
    "commands": {
        "firstRun": [
            {
                "name": "First Run Setup",
                "description": "Generates settings.json and applies database migrations",
                "engine": "python-runtime",
                "exec": "main.py first_run"
            }
        ],
        "run": [
            {
                "name": "UI Server",
                "description": "Launches the Django development server",
                "engine": "python-runtime",
                "exec": "main.py runserver"
            },
            {
                "name": "Ollama Runtime",
                "description": "Launches the managed Ollama service in a dedicated console session",
                "engine": "python-runtime",
                "exec": "main.py ollama_runtime --log"
            }
        ]
    },
    "settings": [
        {
            "key": "ui-port",
            "name": "UI Server Port",
            "description": "Port the UI server listens on",
            "type": "port",
            "default": 30000,
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key ui-port",
            "setExec": "main.py set_setting --key ui-port --value {value}"
        },
        {
            "key": "api-port",
            "name": "API Server Port",
            "description": "Port the UI server listens on",
            "type": "port",
            "default": 30001,
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key api-port",
            "setExec": "main.py set_setting --key api-port --value {value}"
        },
        {
            "key": "console_log_level",
            "name": "Console Log Level",
            "description": "How much runtime detail ASLM-Chat prints into the ASLM console.",
            "type": "select",
            "default": "debug",
            "allowedValues": [
                "basic",
                "debug",
                "trace"
            ],
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key console_log_level",
            "setExec": "main.py set_setting --key console_log_level --value {value}"
        },
        {
            "key": "llm-engine",
            "name": "Active LLM Engine",
            "description": "Engine used for chat generation in the UI",
            "type": "select",
            "default": "ollama-service",
            "allowedValues": [
                "ollama-service",
                "lms",
                "openai",
                "google-genai"
            ],
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key llm-engine",
            "setExec": "main.py set_setting --key llm-engine --value {value}",
            "value": "ollama-service"
        },
        {
            "key": "ollama-service",
            "name": "Ollama",
            "description": "Whether the Ollama inference service is installed",
            "type": "engine",
            "default": false,
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key ollama-service",
            "setExec": "main.py set_setting --key ollama-service --value {value}"
        },
        {
            "key": "ollama-service_path",
            "name": "Ollama Path",
            "description": "Path to the Ollama executable",
            "type": "path",
            "default": null,
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key ollama-service_path",
            "setExec": "main.py set_setting --key ollama-service_path --value {value}"
        },
        {
            "key": "ollama-service_data",
            "name": "Ollama Data",
            "description": "Path to the Ollama data directory",
            "type": "data",
            "default": null,
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key ollama-service_data",
            "setExec": "main.py set_setting --key ollama-service_data --value {value}"
        },
        {
            "key": "ollama-service_models",
            "name": "Ollama Models",
            "description": "Path to the Ollama models directory",
            "type": "models",
            "default": null,
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key ollama-service_models",
            "setExec": "main.py set_setting --key ollama-service_models --value {value}"
        },
        {
            "key": "ollama-service_port",
            "name": "Ollama Port",
            "description": "Port that the local Ollama service listens on",
            "type": "port",
            "default": 30002,
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key ollama-service_port",
            "setExec": "main.py set_setting --key ollama-service_port --value {value}"
        },
        {
            "key": "lms",
            "name": "LM Studio",
            "description": "Whether LM Studio integration is available",
            "type": "engine",
            "default": false,
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key lms",
            "setExec": "main.py set_setting --key lms --value {value}"
        },
        {
            "key": "lms_url",
            "name": "LM Studio Address",
            "description": "Base address of the LM Studio Server API",
            "type": "string",
            "default": "127.0.0.1:1234",
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key lms_url",
            "setExec": "main.py set_setting --key lms_url --value {value}",
            "value": "127.0.0.1:1234"
        },
        {
            "key": "openai",
            "name": "OpenAI-Compatible API",
            "description": "Whether an OpenAI-compatible API endpoint is available",
            "type": "engine",
            "default": false,
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key openai",
            "setExec": "main.py set_setting --key openai --value {value}"
        },
        {
            "key": "openai_url",
            "name": "OpenAI-Compatible Address",
            "description": "Base URL of the OpenAI-compatible API endpoint",
            "type": "string",
            "default": "127.0.0.1:8000/v1",
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key openai_url",
            "setExec": "main.py set_setting --key openai_url --value {value}",
            "value": "127.0.0.1:9000/v1"
        },
        {
            "key": "openai_api_key",
            "name": "OpenAI-Compatible API Key",
            "description": "Optional API key for secured OpenAI-compatible endpoints",
            "type": "password",
            "default": "",
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key openai_api_key",
            "setExec": "main.py set_setting --key openai_api_key --value {value}"
        },
        {
            "key": "google-genai",
            "name": "Google GenAI",
            "description": "Whether Google GenAI integration is available",
            "type": "engine",
            "default": false,
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key google-genai",
            "setExec": "main.py set_setting --key google-genai --value {value}"
        },
        {
            "key": "google_genai_url",
            "name": "Google GenAI Address",
            "description": "Base URL of the Google GenAI Gemini API endpoint",
            "type": "string",
            "default": "generativelanguage.googleapis.com",
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key google_genai_url",
            "setExec": "main.py set_setting --key google_genai_url --value {value}"
        },
        {
            "key": "google_genai_api_key",
            "name": "Google GenAI API Key",
            "description": "API key for Google GenAI Gemini API requests",
            "type": "password",
            "default": "",
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key google_genai_api_key",
            "setExec": "main.py set_setting --key google_genai_api_key --value {value}"
        },
        {
            "key": "yacy",
            "name": "Use YaCy",
            "description": "Whether web-search tools should use and auto-start the local YaCy service.",
            "type": "bool",
            "default": false,
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key use-yacy",
            "setExec": "main.py set_setting --key use-yacy --value {value}"
        },
        {
            "key": "yacy_url",
            "name": "YaCy URL",
            "description": "Base URL of the local YaCy search service.",
            "type": "string",
            "default": "http://localhost:8090",
            "value": "http://localhost:8090",
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key yacy_url",
            "setExec": "main.py set_setting --key yacy_url --value {value}"
        },
        {
            "key": "yacy_user",
            "name": "YaCy Username",
            "description": "Username for YaCy admin authentication.",
            "type": "string",
            "default": "admin",
            "value": "admin",
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key yacy_user",
            "setExec": "main.py set_setting --key yacy_user --value {value}"
        },
        {
            "key": "yacy_pass",
            "name": "YaCy Password",
            "description": "Password for YaCy admin authentication.",
            "type": "password",
            "default": "admin",
            "value": "admin",
            "engine": "python-runtime",
            "getExec": "main.py get_setting --key yacy_pass",
            "setExec": "main.py set_setting --key yacy_pass --value {value}"
        }
    ],
    "status": {
        "installed": false,
        "enabled": false,
        "firstRunCompleted": false
    }
}
